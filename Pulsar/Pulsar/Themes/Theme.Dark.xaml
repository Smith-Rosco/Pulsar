<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="Theme.Window.Background" Color="#181818"/>
    <SolidColorBrush x:Key="Theme.Window.Foreground" Color="#EAEAEA"/>
    <SolidColorBrush x:Key="Theme.Panel.Background" Color="#252526"/>
    <SolidColorBrush x:Key="Theme.Border.Brush" Color="#3F3F46"/>

    <SolidColorBrush x:Key="Theme.Control.Background" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Theme.Control.Hover" Color="#383838"/>
    <SolidColorBrush x:Key="Theme.Control.Pressed" Color="#1F1F1F"/>

    <SolidColorBrush x:Key="Theme.Input.Background" Color="#2D2D30"/>
    <SolidColorBrush x:Key="Theme.Input.Foreground" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="Theme.Text.Primary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary" Color="#AAAAAA"/>

    <SolidColorBrush x:Key="Theme.Accent" Color="#0078D7"/>
    <SolidColorBrush x:Key="Theme.Accent.Hover" Color="#1084E3"/>
    <SolidColorBrush x:Key="Theme.Accent.Foreground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Accent.Pressed" Color="#006CC1"/>
    <SolidColorBrush x:Key="Theme.Destructive" Color="#E81123"/>
    <SolidColorBrush x:Key="Theme.Destructive.Hover" Color="#FF5C2B"/>

    <SolidColorBrush x:Key="SlotTypeBrushDefault" Color="#FF9CA3AF"/>
    <SolidColorBrush x:Key="SlotTypeBrushSecret" Color="#FFF2C14E"/>
    <SolidColorBrush x:Key="SlotTypeBrushApp" Color="#FF4FB3FF"/>
    <SolidColorBrush x:Key="SlotTypeBrushCommand" Color="#FF4ADE80"/>
    <SolidColorBrush x:Key="SlotTypeBrushScript" Color="#FFF87171"/>
    <SolidColorBrush x:Key="SlotTypeBrushVba" Color="#FFF59E0B"/>

    <SolidColorBrush x:Key="SlotHealthBrushReady" Color="#FF4ADE80"/>
    <SolidColorBrush x:Key="SlotHealthBrushWarning" Color="#FFFBBF24"/>
    <SolidColorBrush x:Key="SlotHealthBrushError" Color="#FFF87171"/>

    <SolidColorBrush x:Key="Theme.Orb.Fill" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Theme.Orb.Stroke" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Orb.Active.Glow" Color="#CC00BFFF"/>
    <SolidColorBrush x:Key="Theme.Orb.Text" Color="#FFFFFF"/>

    <sys:Double x:Key="Theme.Orb.BlurOpacity">1.0</sys:Double>

    <!-- Spacing Tokens (4px grid) -->
    <sys:Double x:Key="Pulsar.Spacing.XS">4.0</sys:Double>
    <sys:Double x:Key="Pulsar.Spacing.SM">8.0</sys:Double>
    <sys:Double x:Key="Pulsar.Spacing.MD">16.0</sys:Double>
    <sys:Double x:Key="Pulsar.Spacing.LG">24.0</sys:Double>
    <sys:Double x:Key="Pulsar.Spacing.XL">32.0</sys:Double>

    <!-- Animation Duration Tokens (milliseconds) -->
    <sys:Double x:Key="Pulsar.Animation.Duration.Fast">120.0</sys:Double>
    <sys:Double x:Key="Pulsar.Animation.Duration.Normal">220.0</sys:Double>
    <sys:Double x:Key="Pulsar.Animation.Duration.Slow">380.0</sys:Double>

</ResourceDictionary>
