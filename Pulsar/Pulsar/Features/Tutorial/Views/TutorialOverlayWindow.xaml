<!-- [Path]: Pulsar/Pulsar/Views/Tutorial/TutorialOverlayWindow.xaml -->

<Window x:Class="Pulsar.Features.Tutorial.Views.TutorialOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lex="clr-namespace:Pulsar.Core.Localization"
        mc:Ignorable="d"
        Title="{lex:Locale Tutorial.OverlayTitle}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize">
    
    <Grid x:Name="RootGrid">
        <!-- Semi-transparent overlay background -->
        <Rectangle x:Name="OverlayBackground" 
                   Fill="#B4000000"
                   IsHitTestVisible="False"/>
        
        <!-- Content container for tutorial card (centered) -->
        <ContentPresenter x:Name="CardPresenter"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

        <!-- Confetti overlay layer -->
        <Rectangle x:Name="ConfettiLayer"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

        <!-- Toast notification overlay -->
        <Border x:Name="ToastNotification"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,40,0,0"
                Background="#27AE60"
                CornerRadius="20"
                Padding="16,10,20,10"
                BorderThickness="0"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="16" ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIcon"
                           Text="✓"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="ToastMessage"
                           Text=""
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
