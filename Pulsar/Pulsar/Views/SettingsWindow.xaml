<ui:FluentWindow x:Class="Pulsar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Pulsar.ViewModels"
        xmlns:converters="clr-namespace:Pulsar.Core.Converters"
        mc:Ignorable="d"
        Title="Pulsar Configuration" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.Resources>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.3"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Title="Pulsar Configuration" Grid.Row="0"/>

        <!-- Main Navigation -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation Pane -->
            <ui:NavigationView x:Name="RootNavigation" 
                               Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsPaneOpen="True"
                               OpenPaneLength="250"
                               IsBackButtonVisible="Collapsed">

                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="General" 
                                           Icon="{ui:SymbolIcon Settings24}" 
                                           TargetPageType="{x:Type TypeName=Page}" 
                                           Tag="General"/>
                    
                    <ui:NavigationViewItem Content="Slots" 
                                           Icon="{ui:SymbolIcon DialPad24}" 
                                           TargetPageType="{x:Type TypeName=Page}" 
                                           Tag="Slots"/>

                    <ui:NavigationViewItem Content="Plugins" 
                                           Icon="{ui:SymbolIcon PuzzlePiece24}" 
                                           TargetPageType="{x:Type TypeName=Page}" 
                                           Tag="Plugins"/>

                    <ui:NavigationViewItem Content="Marketplace" 
                                           Icon="{ui:SymbolIcon Store24}" 
                                           TargetPageType="{x:Type TypeName=Page}" 
                                           Tag="Marketplace"/>

                    <ui:NavigationViewItem Content="About" 
                                           Icon="{ui:SymbolIcon Info24}" 
                                           TargetPageType="{x:Type TypeName=Page}" 
                                           Tag="About"/>
                </ui:NavigationView.MenuItems>

                <!-- Footer: Save Button -->
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem 
                        Content="Save Changes"
                        Icon="{ui:SymbolIcon Save24}"
                        Command="{Binding SaveCommand}"
                        ToolTip="Save all changes (Ctrl+S)">
                        
                        <!-- [Phase 4] Red Dot Indicator using InfoBadge with forced style -->
                        <ui:NavigationViewItem.InfoBadge>
                            <ui:InfoBadge>
                                <ui:InfoBadge.Template>
                                    <ControlTemplate TargetType="ui:InfoBadge">
                                        <Ellipse Width="8" Height="8" 
                                                 Fill="#E74856"
                                                 Visibility="{Binding DataContext.HasUnsavedChanges, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                    </ControlTemplate>
                                </ui:InfoBadge.Template>
                            </ui:InfoBadge>
                        </ui:NavigationViewItem.InfoBadge>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <!-- Content Frame -->
        <Frame x:Name="RootFrame"
               Grid.Column="1" 
               Margin="24"
               NavigationUIVisibility="Hidden"/>

        <ui:SnackbarPresenter x:Name="MainSnackbarPresenter" 
                              Grid.Column="1" 
                              VerticalAlignment="Bottom" 
                              HorizontalAlignment="Right" 
                              Margin="0,0,20,20"/>
    </Grid>
    </Grid>
</ui:FluentWindow>