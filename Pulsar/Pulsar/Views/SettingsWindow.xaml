<Window x:Class="Pulsar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Pulsar.ViewModels"
        xmlns:models="clr-namespace:Pulsar.Models"
        xmlns:selectors="clr-namespace:Pulsar.Views.TemplateSelectors"
        mc:Ignorable="d"
        Title="Pulsar Settings" Height="500" Width="800"
        Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <DataTemplate x:Key="LauncherItemTemplate" DataType="{x:Type models:LauncherItem}">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Slot}" VerticalAlignment="Center" Foreground="Gray"/>
                <TextBox Grid.Column="1" Text="{Binding Label}"/>
                <TextBox Grid.Column="2" Text="{Binding ProcessName}" ToolTip="Target Process Name (e.g. chrome)"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CommandItemTemplate" DataType="{x:Type models:CommandItem}">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Slot}" VerticalAlignment="Center" Foreground="Gray"/>
                <TextBox Grid.Column="1" Text="{Binding Label}"/>
                <TextBox Grid.Column="2" Text="{Binding ExePath}" ToolTip="Executable Path"/>
                <TextBox Grid.Column="3" Text="{Binding Arguments}" ToolTip="Arguments"/>
            </Grid>
        </DataTemplate>

        <selectors:SlotTemplateSelector x:Key="SlotSelector"
                                        LauncherTemplate="{StaticResource LauncherItemTemplate}"
                                        CommandTemplate="{StaticResource CommandItemTemplate}"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#252526" Padding="10">
            <StackPanel>
                <TextBlock Text="PULSAR" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#007ACC"/>

                <TextBlock Text="MODES" Foreground="Gray" Margin="0,10,0,5"/>
                <Button Content="🔀 Window Switcher" 
                        Command="{Binding SwitchToLauncherModeCommand}"
                        HorizontalContentAlignment="Left" Padding="10,5" Background="Transparent" Foreground="White" BorderThickness="0"/>

                <TextBlock Text="PROFILES" Foreground="Gray" Margin="0,20,0,5"/>
                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" 
                                    Command="{Binding DataContext.LoadProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    HorizontalContentAlignment="Left" Padding="10,5" Background="Transparent" Foreground="White" BorderThickness="0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{Binding SelectedProfileKey}" FontSize="24"/>
                <TextBlock Text="{Binding IsLauncherMode, StringFormat=' (Mode: {0})'}" Foreground="Gray" VerticalAlignment="Bottom" Margin="10,0,0,4"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding EditableItems}" 
                              ItemTemplateSelector="{StaticResource SlotSelector}"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="+ Add Slot" Command="{Binding AddNewItemCommand}" Padding="15,5" Margin="0,0,10,0"/>
                <Button Content="Save Changes" Command="{Binding SaveConfigCommand}" Padding="15,5" Background="#007ACC" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>