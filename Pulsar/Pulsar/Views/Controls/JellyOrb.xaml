<UserControl x:Class="Pulsar.Views.Controls.JellyOrb"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pulsar.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="60"
             x:Name="OrbRoot"
             RenderTransformOrigin="0.5,0.5">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="OrbScale" ScaleX="1.0" ScaleY="1.0"/>
            <TranslateTransform x:Name="OrbTranslate" X="0" Y="0"/>
        </TransformGroup>
    </UserControl.RenderTransform>

    <Grid Width="{Binding Size, ElementName=OrbRoot}" 
          Height="{Binding Size, ElementName=OrbRoot}">

        <Ellipse x:Name="RecommendedShape" Fill="#FFFFD700" Opacity="0">
            <Ellipse.Effect>
                <BlurEffect Radius="20"/>
            </Ellipse.Effect>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecommended, ElementName=OrbRoot}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.6" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Ellipse x:Name="OrbFill" 
                 Fill="{DynamicResource Theme.Orb.Fill}" 
                 Stroke="{DynamicResource Theme.Orb.Stroke}" 
                 StrokeThickness="1.5">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTransparent, ElementName=OrbRoot}" Value="True">
                            <Setter Property="Fill" Value="Transparent"/>
                            <Setter Property="Stroke" Value="Transparent"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Ellipse x:Name="ActiveShape" Fill="{DynamicResource Theme.Orb.Active.Glow}">
            <Ellipse.Effect>
                <BlurEffect Radius="15"/>
            </Ellipse.Effect>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <!-- Only show if IsActive is True AND ShowActiveGlow is True -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsActive, ElementName=OrbRoot}" Value="True"/>
                                <Condition Binding="{Binding ShowActiveGlow, ElementName=OrbRoot}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="1.0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.EnterActions>
                            <MultiDataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.0" Duration="0:0:0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.ExitActions>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

            <Image Source="{Binding RenderImage, ElementName=OrbRoot}"
                   Width="24" Height="24"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="{Binding ShowImage, ElementName=OrbRoot, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <TextBlock Text="{Binding RenderGlyph, ElementName=OrbRoot}"
                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                       FontSize="20"
                       Foreground="{DynamicResource Theme.Orb.Text}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowImage, ElementName=OrbRoot}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding Label, ElementName=OrbRoot}" 
                       FontSize="11" FontWeight="SemiBold" 
                       Foreground="{DynamicResource Theme.Orb.Text}"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding RenderGlyph, ElementName=OrbRoot}" Value=""/>
                                    <Condition Binding="{Binding ShowImage, ElementName=OrbRoot}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="Panel.ZIndex" Value="0"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Panel.ZIndex" Value="99"/>
                    <Setter Property="Opacity" Value="1.0"/>

                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.15" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase EasingMode="EaseOut" Springiness="4" Oscillations="1"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.15" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase EasingMode="EaseOut" Springiness="4" Oscillations="1"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>

                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
</UserControl>