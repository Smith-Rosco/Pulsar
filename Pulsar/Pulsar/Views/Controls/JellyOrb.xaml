<UserControl x:Class="Pulsar.Views.Controls.JellyOrb"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pulsar.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="60"
             x:Name="OrbRoot"
             RenderTransformOrigin="0.5,0.5">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="OrbScale" ScaleX="1.0" ScaleY="1.0"/>
            <TranslateTransform x:Name="OrbTranslate" X="0" Y="0"/>
        </TransformGroup>
    </UserControl.RenderTransform>

    <Grid Width="{Binding Size, ElementName=OrbRoot}" 
          Height="{Binding Size, ElementName=OrbRoot}">

        <Ellipse x:Name="RecommendedShape" Fill="#FFFFD700" Opacity="0">
            <Ellipse.Effect>
                <BlurEffect Radius="20"/>
            </Ellipse.Effect>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecommended, ElementName=OrbRoot}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.6" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Ellipse x:Name="OrbFill" 
                 StrokeThickness="1.5">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <!-- [New] Halo Effect: Drop Shadow for Contrast -->
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                    <!-- Default: Use Custom Bindings -->
                    <Setter Property="Fill" Value="{Binding CustomFill, ElementName=OrbRoot}"/>
                    <Setter Property="Stroke" Value="{Binding CustomStroke, ElementName=OrbRoot}"/>
                    
                    <Style.Triggers>
                        <!-- Fallback: If CustomFill is Null, use Theme Resource -->
                        <DataTrigger Binding="{Binding CustomFill, ElementName=OrbRoot}" Value="{x:Null}">
                            <Setter Property="Fill" Value="{DynamicResource Theme.Orb.Fill}"/>
                            <Setter Property="Stroke" Value="{DynamicResource Theme.Orb.Stroke}"/>
                            <!-- Remove Halo for default theme if needed, or keep it for better visibility -->
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </DataTrigger>

                        <!-- Transparent Override (Highest Priority) -->
                        <DataTrigger Binding="{Binding IsTransparent, ElementName=OrbRoot}" Value="True">
                            <Setter Property="Fill" Value="Transparent"/>
                            <Setter Property="Stroke" Value="Transparent"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <Ellipse x:Name="ActiveShape">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Opacity" Value="0"/>
                    
                    <!-- 默认绑定到 CustomFill -->
                    <Setter Property="Fill" Value="{Binding CustomFill, ElementName=OrbRoot}"/>
                    
                    <!-- Default Glow Technique: Blur -->
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="20"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Margin" Value="-8"/>

                    <Style.Triggers>
                        <!-- 如果 CustomFill 为空，回退到主题色 -->
                        <DataTrigger Binding="{Binding CustomFill, ElementName=OrbRoot}" Value="{x:Null}">
                            <Setter Property="Fill" Value="{DynamicResource Theme.Orb.Active.Glow}"/>
                        </DataTrigger>

                        <!-- Only show if IsActive is True AND ShowActiveGlow is True -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsActive, ElementName=OrbRoot}" Value="True"/>
                                <Condition Binding="{Binding ShowActiveGlow, ElementName=OrbRoot}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.8" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Effect.Radius" 
                                                         To="25" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.EnterActions>
                            <MultiDataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                         To="0.0" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Effect.Radius" 
                                                         To="10" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.ExitActions>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <!-- [Architectural Fix] Use Viewbox for Scale-Agnostic Rendering -->
        <!-- We define a fixed "Design Coordinate System" (24x24) inside the Viewbox. -->
        <!-- The Viewbox then scales this entire visual tree to fit whatever 'Size' is set externally. -->
        <Viewbox Stretch="Uniform">
            <Grid Width="24" Height="24">
                
                <!-- [New] Opacity Binding for IsContentVisible -->
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                             <DataTrigger Binding="{Binding IsContentVisible, ElementName=OrbRoot}" Value="False">
                                 <Setter Property="Opacity" Value="0"/>
                                 <Setter Property="Visibility" Value="Collapsed"/> 
                             </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
    
            <!-- [Architectural Fix] Reduced Image Size to 16x16 to create Padding/Safe Area -->
            <!-- This ensures square icons never pierce the 24x24 circle boundary -->
            <Image Source="{Binding RenderImage, ElementName=OrbRoot, NotifyOnTargetUpdated=True}"
                   Width="16" Height="16"
                   RenderTransformOrigin="0.5, 0.5"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="{Binding ShowImage, ElementName=OrbRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Image.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.5" To="1" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="1" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Image.Triggers>
                <Image.RenderTransform>
                    <!-- [Refactor] Removed hardcoded CenterX/Y. Origin handled by RenderTransformOrigin -->
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Image.RenderTransform>
            </Image>

            <!-- [Architectural Fix] Reduced Font Size to 14 to match Image scale -->
            <TextBlock Text="{Binding RenderGlyph, ElementName=OrbRoot, NotifyOnTargetUpdated=True}"
                       FontFamily="{Binding GlyphFontFamily, ElementName=OrbRoot}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <!-- Default: Use Custom Foreground -->
                        <Setter Property="Foreground" Value="{Binding CustomForeground, ElementName=OrbRoot}"/>
                        
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowImage, ElementName=OrbRoot}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Fallback: If CustomForeground is Null, use Theme Resource -->
                            <DataTrigger Binding="{Binding CustomForeground, ElementName=OrbRoot}" Value="{x:Null}">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Orb.Text}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- [New] Badge for Multi-Window Count -->
            <!-- [Fix] Added ElementName=OrbRoot to prevent Binding Expression Error 40 -->
            <Border Background="#FF0078D7" 
                    CornerRadius="10" 
                    MinWidth="18" Height="18"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-10,-10,0"
                    Padding="4,0"
                    Panel.ZIndex="100">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <!-- Only show if BadgeCount > 1 -->
                            <DataTrigger Binding="{Binding BadgeCount, ElementName=OrbRoot}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BadgeCount, ElementName=OrbRoot}" Value="1">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BadgeCount, ElementName=OrbRoot}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding BadgeCount, ElementName=OrbRoot}" 
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Border>
    
                <TextBlock Text="{Binding Label, ElementName=OrbRoot}"
                           FontSize="11" FontWeight="SemiBold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Foreground" Value="{Binding CustomForeground, ElementName=OrbRoot}"/>
    
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding RenderGlyph, ElementName=OrbRoot}" Value=""/>
                                        <Condition Binding="{Binding ShowImage, ElementName=OrbRoot}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <!-- Fallback: If CustomForeground is Null, use Theme Resource -->
                                <DataTrigger Binding="{Binding CustomForeground, ElementName=OrbRoot}" Value="{x:Null}">
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.Orb.Text}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Viewbox>
    </Grid>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="Panel.ZIndex" Value="0"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Panel.ZIndex" Value="99"/>
                    <Setter Property="Opacity" Value="1.0"/>

                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.15" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase EasingMode="EaseOut" Springiness="4" Oscillations="1"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.15" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase EasingMode="EaseOut" Springiness="4" Oscillations="1"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>

                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
</UserControl>