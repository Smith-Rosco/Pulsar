<Window x:Class="Pulsar.Views.RadialMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:Pulsar.Views.Controls"
        xmlns:converters="clr-namespace:Pulsar.Core.Converters"
        xmlns:vm="clr-namespace:Pulsar.ViewModels"
        xmlns:lex="clr-namespace:Pulsar.Core.Localization"
        mc:Ignorable="d"
    Title="{lex:Locale RadialMenu.Title}"
    Width="500" Height="500"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    x:Name="RootWindow"
    Style="{x:Null}"
    RenderOptions.BitmapScalingMode="LowQuality"
    RenderOptions.CacheInvalidationThresholdMinimum="0.5"
    RenderOptions.CacheInvalidationThresholdMaximum="2.0">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>
            <sys:Boolean x:Key="FalseValue">False</sys:Boolean>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- [Refactor] Compact Mode: Window is now exact size of menu. Canvas handles interaction. -->
        <Canvas x:Name="MenuCanvas"
                Background="Transparent"
                Width="500" Height="500"
                HorizontalAlignment="Left" VerticalAlignment="Top">

            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid RenderTransformOrigin="0.5,0.5"
                              Opacity="{Binding CurrentOpacity}">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding CurrentScale, FallbackValue=1}" ScaleY="{Binding CurrentScale, FallbackValue=1}"/>
                                    <TranslateTransform X="{Binding RenderOffsetX, FallbackValue=0}" Y="{Binding RenderOffsetY, FallbackValue=0}"/>
                                </TransformGroup>
                            </Grid.RenderTransform>

                            <controls:SlotOrb RenderTransformOrigin="0.5,0.5"
                                               IconKey="{Binding IconKey}"
                                               OrbImage="{Binding IconImage}"
                                               Label="{Binding Label}"
                                               IsActive="{Binding IsActive}"
                                               IsRecommended="{Binding IsRecommended}"
                                               Size="{Binding Size}"
                                               IsEnabled="{Binding IsEnabled}"
                                               BadgeCount="{Binding BadgeCount}"
                                               CustomFill="{Binding CustomFillBrush}"
                                               CustomStroke="{Binding CustomStrokeBrush}"
                                               CustomForeground="{Binding CustomForegroundBrush}"/>

                             <Border HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,-6,-6,0"
                                     Style="{StaticResource SlotChipBorderStyle}"
                                     Background="#B20B1220"
                                     Padding="6,2"
                                     Visibility="{Binding ShowTypeBadge, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                <TextBlock Text="{Binding TypeBadge}"
                                           Style="{StaticResource SlotValueChipTextStyle}"
                                           FontSize="9">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource SlotBrushConverter}" ConverterParameter="Type">
                                            <Binding Path="TypeToneKey"/>
                                            <Binding RelativeSource="{RelativeSource Self}"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                             </Border>
                         </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- [New] Center Container for Morphing Effect (Simplified) -->
            <Grid Width="500" Height="500" Canvas.Left="0" Canvas.Top="0">
                
                <!-- Shared Background Container -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    
                    <!-- 1. Center Orb Wrapper (Normal State) -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        
                        <!-- Normal slot orb (overlay/fallback) -->
                        <controls:SlotOrb 
                            DataContext="{Binding CenterSlot}"
                            Size="{Binding Size}"
                            IsActive="{Binding IsActive}"
                            IsRecommended="{Binding IsRecommended}"
                            Label="{Binding Label}"
                            IconKey="{Binding IconKey}"
                            OrbImage="{Binding IconImage}"
                            BadgeCount="{Binding BadgeCount}"
                            CustomFill="{Binding CustomFillBrush}"
                            CustomStroke="{Binding CustomStrokeBrush}"
                             CustomForeground="{Binding CustomForegroundBrush}">
                              <controls:SlotOrb.Style>
                                <Style TargetType="controls:SlotOrb">
                                    <!-- Default: Transparent (Preview Visible) -->
                                    <Setter Property="IsTransparent" Value="True"/>
                                    <!-- [New] Hide Content if Preview is Visible -->
                                    <Setter Property="IsContentVisible" Value="False"/>
                                     
                                     <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.HasPreview, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="IsTransparent" Value="False"/>
                                            <Setter Property="IsContentVisible" Value="True"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                              </controls:SlotOrb.Style>
                        </controls:SlotOrb>

                        <!-- [New] Center Preview Layers (Fade & Scale) -->
                        <Grid IsHitTestVisible="False">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.8" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.8" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasLivePreview}" Value="True">
                                            <Setter Property="Opacity" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Ellipse Width="{Binding Size}" Height="{Binding Size}">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding CenterPreviewImage}" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                                <Ellipse.Stroke>
                                    <SolidColorBrush Color="White" Opacity="0.2"/>
                                </Ellipse.Stroke>
                                <Ellipse.StrokeThickness>1</Ellipse.StrokeThickness>
                            </Ellipse>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>

            <!-- [Optimized] Dynamic Title with Hard Shadow (No DropShadowEffect for Performance) -->

            <!-- [New] Halo Dimmer Background (Simulated Frost) -->
            <!-- Placed BEHIND the center orb but visually it serves as a backdrop. 
                 Actually, it should be at ZIndex -1 relative to Slots if we want Slots on top?
                 Currently Slots are drawn first (Z-Order bottom), then Center Container.
                 Wait, ItemsControl (Slots) is defined BEFORE Center Container. So Slots are BELOW Center Container?
                 Yes.
                 To put this BEHIND everything, we should put it as the FIRST child of Canvas. -->

            <!-- [Optimized] Dynamic Title with Hard Shadow (No DropShadowEffect for Performance) -->
            <Grid Canvas.Left="0" 
                  Canvas.Top="{Binding TitleTopOffset}" 
                  Width="500"
                  IsHitTestVisible="False">
                
                <!-- Shadow Layer (Offset 1px) -->
                <TextBlock Text="{Binding DynamicTitle, NotifyOnTargetUpdated=True}"
                           TextAlignment="Center"
                           Foreground="Black"
                           FontSize="16" FontWeight="SemiBold"
                           Opacity="0.5"
                           Margin="1,1,0,0">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.5" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>

                <!-- Foreground Layer -->
                <TextBlock Text="{Binding DynamicTitle, NotifyOnTargetUpdated=True}"
                           TextAlignment="Center"
                           Foreground="#DDFFFFFF"
                           FontSize="16" FontWeight="SemiBold">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Grid>
        </Canvas>
    </Grid>
</Window>
