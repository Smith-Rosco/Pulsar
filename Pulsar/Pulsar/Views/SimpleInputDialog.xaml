<ui:FluentWindow x:Class="Pulsar.Views.SimpleInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Input" Height="200" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Input" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,20">
            <TextBlock x:Name="MessageText" Text="Please enter value:" Margin="0,0,0,10"/>
            <ui:TextBox x:Name="InputTextBox" Padding="5" Focusable="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancel" IsCancel="True" Width="80" Appearance="Secondary" Margin="0,0,10,0"/>
            <ui:Button Content="OK" IsDefault="True" Click="Ok_Click" Width="80" Appearance="Primary"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>