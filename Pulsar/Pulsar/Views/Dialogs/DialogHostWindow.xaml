<ui:FluentWindow x:Class="Pulsar.Views.Dialogs.DialogHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Pulsar.Views.Dialogs"
        xmlns:viewmodels="clr-namespace:Pulsar.ViewModels"
        xmlns:dialogs="clr-namespace:Pulsar.ViewModels.Dialogs"
        xmlns:contents="clr-namespace:Pulsar.Views.Dialogs.Contents"
        xmlns:enums="clr-namespace:Pulsar.Models.Enums"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <!-- Type Converter for checking if Content is string -->
            <local:TypeToBooleanConverter x:Key="TypeConverter"/>
            
            <!-- Default String Template -->
            <DataTemplate DataType="{x:Type sys:String}">
                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource Theme.Text.Primary}"/>
            </DataTemplate>
            
            <!-- Dialog ViewModel Templates -->
            <DataTemplate DataType="{x:Type dialogs:ProcessBlacklistViewModel}">
                <contents:ProcessBlacklistContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:ColorPickerViewModel}">
                <contents:ColorPickerContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:IconPickerViewModel}">
                <contents:IconPickerContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:InputDialogViewModel}">
                <contents:InputDialogContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:InputProfileViewModel}">
                <contents:InputProfileContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:EditProfileViewModel}">
                <contents:EditProfileContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:PermissionRequestViewModel}">
                <contents:PermissionRequestContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:PluginLogViewerViewModel}">
                <contents:PluginLogViewerContentHost/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:ProcessPickerViewModel}">
                <contents:ProcessPickerContent/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type dialogs:QuickSecretsViewModel}">
                <contents:QuickSecretsContent/>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource Theme.Background}"
            BorderBrush="{DynamicResource Theme.Border.Brush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <ui:TitleBar Title="{Binding Title}" 
                         Grid.Row="0"
                         ShowMaximize="{Binding ShowMaximizeButton, RelativeSource={RelativeSource AncestorType=Window}}"
                         ShowMinimize="{Binding ShowMaximizeButton, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,15,20,20">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScrollable}" Value="False">
                                <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Icon Area (only for string content with DialogType) -->
                    <ui:SymbolIcon Grid.Column="0" 
                                   FontSize="24" 
                                   Margin="0,0,15,0"
                                   VerticalAlignment="Top">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <!-- Show icon only for string content -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Content, Converter={StaticResource TypeConverter}, ConverterParameter={x:Type sys:String}}" Value="True"/>
                                            <Condition Binding="{Binding DialogType}" Value="Info"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Symbol" Value="Info24"/>
                                        <Setter Property="Foreground" Value="#0078D4"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Content, Converter={StaticResource TypeConverter}, ConverterParameter={x:Type sys:String}}" Value="True"/>
                                            <Condition Binding="{Binding DialogType}" Value="Warning"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Symbol" Value="Warning24"/>
                                        <Setter Property="Foreground" Value="#FFA500"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Content, Converter={StaticResource TypeConverter}, ConverterParameter={x:Type sys:String}}" Value="True"/>
                                            <Condition Binding="{Binding DialogType}" Value="Error"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Symbol" Value="ErrorCircle24"/>
                                        <Setter Property="Foreground" Value="#D13438"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Content, Converter={StaticResource TypeConverter}, ConverterParameter={x:Type sys:String}}" Value="True"/>
                                            <Condition Binding="{Binding DialogType}" Value="Success"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Symbol" Value="CheckmarkCircle24"/>
                                        <Setter Property="Foreground" Value="#107C10"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>
                    
                    <!-- Content Area -->
                    <ContentPresenter Grid.Column="1" Content="{Binding Content}"/>
                </Grid>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Theme.Control.Background}"
                    Padding="20,15"
                    CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Tertiary Button (e.g., "Don't Save" or "No" in 3-button dialogs) -->
                    <ui:Button Content="{Binding TertiaryButtonText}"
                               Visibility="{Binding IsTertiaryButtonVisible, Converter={StaticResource BoolToVis}}"
                               Command="{Binding CloseCommand}"
                               Margin="0,0,10,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="MinWidth" Value="80"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseDangerStyleForTertiary}" Value="True">
                                        <Setter Property="Background" Value="#D13438"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#D13438"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding UseDangerStyleForTertiary}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                        <ui:Button.CommandParameter>
                            <enums:DialogResult>No</enums:DialogResult>
                        </ui:Button.CommandParameter>
                    </ui:Button>

                    <!-- Secondary Button (e.g., "Cancel") -->
                    <ui:Button Content="{Binding SecondaryButtonText}"
                               Visibility="{Binding IsSecondaryButtonVisible, Converter={StaticResource BoolToVis}}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Command="{Binding CloseCommand}"
                               Margin="0,0,10,0">
                        <ui:Button.CommandParameter>
                            <enums:DialogResult>Cancelled</enums:DialogResult>
                        </ui:Button.CommandParameter>
                    </ui:Button>

                    <!-- Primary Button (e.g., "Save" or "OK") -->
                    <ui:Button Content="{Binding PrimaryButtonText}"
                               Visibility="{Binding IsPrimaryButtonVisible, Converter={StaticResource BoolToVis}}"
                               Style="{StaticResource PulsarPrimaryButtonStyle}"
                               Command="{Binding CloseCommand}"
                               IsDefault="True">
                        <ui:Button.CommandParameter>
                            <enums:DialogResult>Confirmed</enums:DialogResult>
                        </ui:Button.CommandParameter>
                    </ui:Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
