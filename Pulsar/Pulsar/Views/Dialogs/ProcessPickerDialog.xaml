<Window x:Class="Pulsar.Views.Dialogs.ProcessPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Process" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource Theme.Window.Background}"
        Foreground="{DynamicResource Theme.Window.Foreground}"
        BorderBrush="{DynamicResource Theme.Accent}"
        BorderThickness="1">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Name="Border" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="4" Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Theme.Accent}"/>
                                <Setter TargetName="Border" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Theme.Control.Hover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select Application" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"
                   Foreground="{DynamicResource Theme.Window.Foreground}"/>

        <Border Grid.Row="1" Background="{DynamicResource Theme.Input.Background}" CornerRadius="4" Padding="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" Margin="5,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource Theme.Text.Secondary}"/>
                <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" 
                         Background="Transparent" BorderThickness="0" 
                         Foreground="{DynamicResource Theme.Input.Foreground}"
                         CaretBrush="{DynamicResource Theme.Input.Foreground}"
                         VerticalContentAlignment="Center"
                         Tag="Search running apps..."/>
            </Grid>
        </Border>

        <ListBox Grid.Row="2" x:Name="ProcessList" 
                 Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="ProcessList_MouseDoubleClick"
                 Foreground="{DynamicResource Theme.Window.Foreground}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="32" Height="32" Margin="0,0,10,0">
                            <Border Background="#1A888888" CornerRadius="4">
                                <TextBlock Text="📦" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center" 
                                           FontSize="16" Opacity="0.5"
                                           Foreground="{DynamicResource Theme.Window.Foreground}"/>
                            </Border>

                            <Image Source="{Binding AppIcon}" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" 
                                       FontWeight="SemiBold" 
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource Theme.Window.Foreground}"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ProcessName}" 
                                           FontSize="11" Opacity="0.7"
                                           Foreground="{DynamicResource Theme.Window.Foreground}"/>

                                <TextBlock Text=" • " FontSize="11" Opacity="0.5"
                                           Foreground="{DynamicResource Theme.Window.Foreground}"/>

                                <TextBlock Text="{Binding ExePath}" 
                                           FontSize="11" Opacity="0.5" 
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Theme.Window.Foreground}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Click="Cancel_Click" 
                    Background="Transparent" BorderThickness="0" 
                    Foreground="{DynamicResource Theme.Text.Secondary}" Margin="0,0,10,0"/>
            <Button Content="Select" Click="Select_Click" 
                    Background="{DynamicResource Theme.Accent}" Foreground="White"
                    Padding="15,5" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>