<ui:FluentWindow x:Class="Pulsar.Views.Dialogs.QuickSecretsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Secret Configuration" Height="480" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Secret Configuration" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Label / Alias (Required)" FontWeight="Bold" Margin="0,0,0,5"/>
            <ui:TextBox x:Name="TxtLabel" PlaceholderText="e.g. GitHub Token" Margin="0,0,0,15"/>

            <TextBlock Text="Target Context (Process Name)" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="TxtProcess" PlaceholderText="e.g. chrome" Icon="{ui:SymbolIcon AppGeneric24}"/>
                <ui:Button Content="Pick" Width="50" Margin="5,0,0,0" Grid.Column="1" Click="BtnPick_Click"
                           Icon="{ui:SymbolIcon TargetEdit20}" Appearance="Secondary"/>
            </Grid>

            <TextBlock Text="Username / Account (Optional)" FontWeight="Bold" Margin="0,0,0,5"/>
            <ui:TextBox x:Name="TxtAccount" PlaceholderText="user@example.com" Icon="{ui:SymbolIcon Person24}" Margin="0,0,0,15"/>

            <TextBlock Text="Password" FontWeight="Bold" Margin="0,0,0,5"/>
            <ui:PasswordBox x:Name="TxtPassword" PlaceholderText="••••••••" Icon="{ui:SymbolIcon LockClosed24}"/>
            <TextBlock x:Name="TxtPasswordHint" 
                       Text="Leave blank to keep current password" 
                       FontSize="11" Opacity="0.6" Margin="0,5,0,15"
                       Visibility="Collapsed"/>

            <CheckBox x:Name="ChkAutoEnter" Content="Auto Press Enter after injection" 
                      Margin="0,15,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <ui:Button Content="Cancel" Width="80" Margin="0,0,10,0" IsCancel="True" Appearance="Secondary"/>
                <ui:Button Content="Save Secret" Width="100" Click="BtnSave_Click" IsDefault="True" Appearance="Primary"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>