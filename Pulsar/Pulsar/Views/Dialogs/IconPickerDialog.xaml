<ui:FluentWindow x:Class="Pulsar.Views.Dialogs.IconPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Pulsar.Views.Controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Select Icon" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- Search & Browse -->
            <RowDefinition Height="*"/>    <!-- Icons List -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Select Icon" Grid.Row="0"/>

        <!-- Search and Browse Section -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox x:Name="SearchBox" 
                        TextChanged="SearchBox_TextChanged"
                        PlaceholderText="Filter system icons (e.g. 'settings', 'user')..." 
                        Icon="{ui:SymbolIcon Search24}"/>

            <ui:Button Grid.Column="1" Click="BrowseFile_Click" Margin="12,0,0,0"
                       Icon="{ui:SymbolIcon FolderOpen24}"
                       Content="Browse File" 
                       Style="{StaticResource PulsarSecondaryButtonStyle}"/>
        </Grid>

        <!-- Icons Grid -->
        <Border Grid.Row="2" 
                Background="{DynamicResource ControlFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" 
                BorderThickness="1"
                CornerRadius="8" 
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="IconList" ItemsSource="{Binding FilteredIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="10"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Click="Icon_Click" Tag="{Binding Code}"
                                       Appearance="Transparent" 
                                       Padding="4" Margin="2"
                                       ToolTip="{Binding Name}"
                                       Height="56" Width="56"
                                       CornerRadius="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Character}" 
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ui:Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer Section -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Preview:" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <controls:JellyOrb x:Name="PreviewOrb" Size="42" IsActive="False" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                     <TextBlock Text="Selected Icon" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                     <TextBlock x:Name="ResultText" Text="{Binding SelectedKey}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel" IsCancel="True" Click="Cancel_Click"
                           Width="90" Style="{StaticResource PulsarSecondaryButtonStyle}" Margin="0,0,12,0"/>
                
                <ui:Button Content="Select" IsDefault="True" Click="Select_Click"
                           Width="90" Style="{StaticResource PulsarPrimaryButtonStyle}"
                           Icon="{ui:SymbolIcon Checkmark24}"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
