<UserControl x:Class="Pulsar.Views.Dialogs.Contents.AddSlotContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:lex="clr-namespace:Pulsar.Core.Localization"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:models="clr-namespace:Pulsar.Models"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:controls="clr-namespace:Pulsar.Views.Controls"
             mc:Ignorable="d"
             MinWidth="760"
             MinHeight="520"
             d:DataContext="{d:DesignInstance Type=viewmodels:SlotEditorViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="BoolToVisInverse"/>
            <converters:StringToBoolConverter x:Key="StringToBool"/>

            <!-- Text styles -->
            <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompactSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="CompactStatusBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CompactStatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Intent card button style -->
            <Style x:Key="IntentCardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="220"/>
                <Setter Property="Height" Value="120"/>
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="Margin" Value="0,0,10,10"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Browse-all card button style (smaller) -->
            <Style x:Key="BrowseCardButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0,0,8,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BrowseBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BrowseBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="BrowseBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented action button style -->
            <Style x:Key="SegmentedActionButtonStyle" TargetType="RadioButton">
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="SegBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SegBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="SegBorder" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                    <Setter TargetName="SegBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Parameter field template -->
            <DataTemplate x:Key="SlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Label}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" *"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Width="26"
                                   Height="26"
                                   Padding="5"
                                   Margin="0,0,6,0"
                                   Icon="{ui:SymbolIcon FolderOpen16}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   ToolTip="{lex:Locale Dialog.AddSlot.BrowseIcon}"
                                   Click="SlotParameterPicker_Click"
                                   Tag="{Binding}"
                                   Visibility="{Binding HasPicker, Converter={StaticResource BoolToVis}}"/>

                        <ui:ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding Value, Mode=TwoWay, Converter={StaticResource StringToBool}}"
                                         Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVis}}"/>

                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{Binding Placeholder}"
                                    Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVisInverse}}">
                            <ui:TextBox.Style>
                                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSecretSelector}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBox.Style>
                        </ui:TextBox>

                        <Border Grid.Column="1"
                                Visibility="{Binding IsSecretSelector, Converter={StaticResource BoolToVis}}"
                                Padding="10,7"
                                CornerRadius="6"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayValue}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SecondaryDisplayValue}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding HasSecondaryDisplayValue, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,16,20,16">

            <Grid>
                <!-- ===================== PHASE 1: PICKER ===================== -->
                <StackPanel Visibility="{Binding IsPickerPhase, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{lex:Locale Dialog.AddSlot.CreateSlot}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,4"/>

                <!-- Search box -->
                <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{lex:Locale Dialog.AddSlot.SearchPlaceholder}"
                            Margin="0,0,0,16"/>

                <!-- Curated intent card grid (3×2) -->
                <ItemsControl ItemsSource="{Binding PrimaryCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource IntentCardButtonStyle}"
                                    Command="{Binding DataContext.SelectSlotTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Width="36" Height="36" CornerRadius="9"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                        <controls:SlotOrb Size="28" Width="28" Height="28"
                                                          Opacity="1" IsActive="False"
                                                          IsHitTestVisible="False"
                                                          ShowActiveGlow="False"
                                                          IsTransparent="True"
                                                          IconKey="{Binding IconKey}"/>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="28"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Browse all slot types... -->
                <ui:CardExpander Header="{lex:Locale Dialog.AddSlot.BrowseAll}"
                                 IsExpanded="{Binding IsBrowseExpanded, Mode=TwoWay}"
                                 Margin="0,8,0,0"
                                 HorizontalContentAlignment="Stretch">
                    <ItemsControl ItemsSource="{Binding BrowseAllCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Key}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding .}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource BrowseCardButtonStyle}"
                                                        Command="{Binding DataContext.SelectSlotTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="24" Height="24" CornerRadius="6"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                Margin="0,0,8,0">
                                                            <controls:SlotOrb Size="18" Width="18" Height="18"
                                                                              Opacity="1" IsActive="False"
                                                                              IsHitTestVisible="False"
                                                                              ShowActiveGlow="False"
                                                                              IsTransparent="True"
                                                                              IconKey="{Binding IconKey}"/>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="200"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ui:CardExpander>
            </StackPanel>

            <!-- ===================== PHASE 2: CONFIGURATION ===================== -->
            <StackPanel Visibility="{Binding IsConfigurationPhase, Converter={StaticResource BoolToVis}}">
                <!-- Header: back arrow (create only) + orb + label + status badge -->
                <Border Padding="0,0,0,16"
                        Margin="0,0,0,16"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Back arrow (Create mode only) -->
                        <ui:Button Grid.Column="0"
                                   Width="28" Height="28"
                                   Padding="4"
                                   Icon="{ui:SymbolIcon ArrowLeft24}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   Command="{Binding GoBackToPickerCommand}"
                                   Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVis}}"
                                   Margin="0,0,10,0"
                                   ToolTip="{lex:Locale Dialog.AddSlot.BackToPicker}"/>

                        <!-- Orb -->
                        <controls:SlotOrb Grid.Column="1"
                                          Size="34" Width="34" Height="34"
                                          Opacity="1" IsActive="False"
                                          IsHitTestVisible="False"
                                          ShowActiveGlow="False"
                                          IsTransparent="True"
                                          IconKey="{Binding Slot.IconKey}"
                                          CustomFill="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                          CustomStroke="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                          Margin="0,0,10,0"/>

                        <!-- Label + header text -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HeaderText}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <!-- Status badge -->
                        <Border Grid.Column="3"
                                Style="{StaticResource HeaderStatusBadgeBorderStyle}"
                                Margin="10,0,0,0">
                            <TextBlock Text="{Binding HeaderStatusText}"
                                       Style="{StaticResource HeaderStatusBadgeTextStyle}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- === BEHAVIOR SECTION === -->
                <TextBlock Text="{lex:Locale Dialog.AddSlot.Behavior}"
                           Style="{StaticResource SectionEyebrowTextStyle}"/>

                <!-- Action selector -->
                <Border Padding="0,0,0,10">
                    <StackPanel>
                        <!-- Validation error banner -->
                        <Border Margin="0,0,0,8"
                                Padding="12,10"
                                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding HasActionValidationError, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ActionValidationMessage}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Single action: read-only label -->
                        <TextBlock Text="{Binding Slot.ActionLabel}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVis}}"
                                   Margin="0,4,0,0"/>

                        <!-- Segmented button group (2-4 actions) -->
                        <Grid Visibility="{Binding UseSegmentedButtons, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding AvailableActions}"
                                          x:Name="ActionChoiceSection">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Style="{StaticResource SegmentedActionButtonStyle}"
                                                     GroupName="SlotActions"
                                                     IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                     Content="{Binding Label}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- ComboBox fallback (5+ actions) -->
                        <ComboBox ItemsSource="{Binding AvailableActions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding Slot.Action}"
                                  Visibility="{Binding UseComboBox, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- Summary tokens -->
                <ItemsControl ItemsSource="{Binding SummaryTokens}"
                              Visibility="{Binding HasSummaryTokens, Converter={StaticResource BoolToVis}}"
                              Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,2" CornerRadius="4"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,6,4">
                                <TextBlock Text="{Binding}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Required parameters -->
                <ItemsControl ItemsSource="{Binding RequiredParameters}"
                              ItemTemplate="{StaticResource SlotParameterFieldTemplate}"
                              Visibility="{Binding HasRequiredParameters, Converter={StaticResource BoolToVis}}"/>

                <!-- Compact status border -->
                <Border Style="{StaticResource CompactStatusBorderStyle}"
                        Margin="0,8,0,0"
                        Visibility="{Binding HasValidationSummary, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ValidationSummary}"
                               Style="{StaticResource CompactStatusTextStyle}"/>
                </Border>

                <!-- === APPEARANCE SECTION === -->
                <ui:CardExpander Header="{lex:Locale Dialog.AddSlot.Appearance}"
                                 IsExpanded="{Binding IsAppearanceExpanded, Mode=OneWay}"
                                 Margin="0,14,0,0"
                                 HorizontalContentAlignment="Stretch"
                                 Visibility="{Binding HasAppearanceOptions, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,4,0,0">
                        <!-- Label -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{lex:Locale Dialog.AddSlot.Label}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding Slot.Label, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="{lex:Locale Dialog.AddSlot.DisplayLabelPlaceholder}"/>
                        </Grid>

                        <!-- Color -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{lex:Locale Dialog.AddSlot.Color}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="56" Height="36"
                                        CornerRadius="8"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1"
                                        Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                        Cursor="Hand"
                                        ToolTip="{lex:Locale Dialog.AddSlot.PickColor}"
                                        MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Drop24"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Icon -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{lex:Locale Dialog.AddSlot.Icon}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <controls:IconSelector Grid.Column="1"
                                                    IconKey="{Binding Slot.IconKey}"
                                                    BrowseClicked="PickIcon_Click"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- === ADVANCED SECTION === -->
                <ui:CardExpander Header="{lex:Locale Dialog.AddSlot.Advanced}"
                                 IsExpanded="{Binding IsAdvancedExpanded, Mode=OneWay}"
                                 Margin="0,10,0,0"
                                 HorizontalContentAlignment="Stretch"
                                 Visibility="{Binding HasOptionalSettings, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,4,0,0">
                        <ItemsControl ItemsSource="{Binding OptionalParameters}"
                                      ItemTemplate="{StaticResource SlotParameterFieldTemplate}"
                                      Visibility="{Binding HasOptionalParameters, Converter={StaticResource BoolToVis}}"/>

                        <Border Margin="0,14,0,0"
                                Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{lex:Locale Dialog.AddSlot.Advanced}"
                                           Style="{StaticResource CompactSectionTitleTextStyle}"
                                           Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding AdvancedParameters}"
                                              ItemTemplate="{StaticResource SlotParameterFieldTemplate}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
