<UserControl x:Class="Pulsar.Views.Dialogs.Contents.AddSlotContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:models="clr-namespace:Pulsar.Models"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:controls="clr-namespace:Pulsar.Views.Controls"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             MinWidth="760"
             MinHeight="520"
             d:DataContext="{d:DesignInstance Type=viewmodels:AddSlotViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="BoolToVisInverse"/>
            <converters:StringToBoolConverter x:Key="StringToBool"/>

            <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompactSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="WorkflowDividerStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="0,0,0,16"/>
            </Style>

            <Style x:Key="PickerItemNameTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PickerSelectedBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="6,1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PickerSelectedBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>



            <Style x:Key="ParameterCardBorderStyle" TargetType="Border">
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style x:Key="ConfigurationExpanderStyle" TargetType="Expander">
                <Setter Property="Margin" Value="0,10,0,0"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="CompactStatusBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CompactStatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PickerCategoryButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CategoryBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <TextBlock x:Name="CategoryText"
                                           Text="{TemplateBinding Content}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                    <Setter TargetName="CategoryText" Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PluginTypeCardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="200"/>
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PickerBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FlowToggleButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="FlowBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="FlowBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="FlowBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="FlowBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="FlowBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScenarioCardButtonStyle" TargetType="Button" BasedOn="{StaticResource PluginTypeCardButtonStyle}">
                <Setter Property="Width" Value="316"/>
                <Setter Property="MinHeight" Value="88"/>
                <Setter Property="Padding" Value="12,12"/>
            </Style>

            <DataTemplate x:Key="CreateSlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Label -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Label}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" *"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: Picker button + Value -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Width="26"
                                   Height="26"
                                   Padding="5"
                                   Margin="0,0,6,0"
                                   Icon="{ui:SymbolIcon FolderOpen16}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   ToolTip="Browse"
                                   Click="SlotParameterPicker_Click"
                                   Tag="{Binding}"
                                   Visibility="{Binding HasPicker, Converter={StaticResource BoolToVis}}"/>

                        <!-- Bool type: ToggleSwitch -->
                        <ui:ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding Value, Mode=TwoWay, Converter={StaticResource StringToBool}}"
                                         Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVis}}"/>

                        <!-- Other types: Editable TextBox -->
                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{Binding Placeholder}"
                                    Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVisInverse}}"/>
                    </Grid>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,0,20,0">
            <StackPanel Margin="0,0,0,16">
                <Border Padding="0,0,0,16"
                        Margin="0,0,0,18"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding HeaderText}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>

                            <Border Margin="10,2,0,0"
                                    Style="{StaticResource HeaderStatusBadgeBorderStyle}">
                                <TextBlock Text="{Binding HeaderStatusText}"
                                           Style="{StaticResource HeaderStatusBadgeTextStyle}"/>
                            </Border>
                        </WrapPanel>

                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="332"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Choose behavior"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="{Binding PluginPickerHint}"
                                   Style="{StaticResource SectionBodyTextStyle}"
                                   Margin="0,0,0,10"/>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Style="{StaticResource FlowToggleButtonStyle}"
                                    Command="{Binding ShowScenarioFlowCommand}">
                                <StackPanel>
                                    <TextBlock Text="Scenario-Based"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Start from common intent"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource FlowToggleButtonStyle}"
                                    Command="{Binding ShowAdvancedFlowCommand}">
                                <StackPanel>
                                    <TextBlock Text="Advanced"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Choose plugin and action manually"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <StackPanel Visibility="{Binding IsScenarioMode, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding ScenarioOptions}"
                                          Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ScenarioCardButtonStyle}"
                                                Command="{Binding DataContext.SelectScenarioCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="36"
                                                        Height="36"
                                                        CornerRadius="9"
                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        Margin="0,0,12,0">
                                                    <controls:SlotOrb Size="28"
                                                                      Width="28"
                                                                      Height="28"
                                                                      Opacity="1"
                                                                      IsActive="False"
                                                                      IsHitTestVisible="False"
                                                                      ShowActiveGlow="False"
                                                                      IsTransparent="True"
                                                                      IconKey="{Binding IconKey}"/>
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource PickerItemNameTextStyle}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource SectionBodyTextStyle}"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Padding="12,10"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Text="Need something else? Switch to Advanced to pick any plugin and full parameter model manually."
                                           Style="{StaticResource SectionBodyTextStyle}"/>
                            </Border>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding PluginTypeCategories}"
                                      Margin="0,0,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsAdvancedMode}" Value="True"/>
                                                <Condition Binding="{Binding HasPickerCategories}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PickerCategoryButtonStyle}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DisplayLabel}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding FilteredPluginTypes}"
                                      Margin="0,4,0,0"
                                      Visibility="{Binding IsAdvancedMode, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PluginTypeCardButtonStyle}"
                                            Command="{Binding DataContext.SelectPluginTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.ToolTip>
                                            <ToolTip Content="{Binding Description}"
                                                     MaxWidth="260"/>
                                        </Button.ToolTip>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="8"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    Margin="0,0,10,0">
                                                <controls:SlotOrb Size="24"
                                                                  Width="24"
                                                                  Height="24"
                                                                  Opacity="1"
                                                                  IsActive="False"
                                                                  IsHitTestVisible="False"
                                                                  ShowActiveGlow="False"
                                                                  IsTransparent="True"
                                                                  IconKey="{Binding IconKey}"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource PickerItemNameTextStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Configure slot"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>

                        <StackPanel Visibility="{Binding HasSelectedPlugin, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource WorkflowDividerStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <controls:SlotOrb Grid.Column="0"
                                                          Size="34"
                                                          Width="34"
                                                          Height="34"
                                                          Opacity="1"
                                                          IsActive="False"
                                                          IsHitTestVisible="False"
                                                          ShowActiveGlow="False"
                                                          IsTransparent="True"
                                                          IconKey="{Binding Slot.IconKey}"
                                                          CustomFill="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                                          CustomStroke="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"/>

                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0,12,0">
                                            <TextBlock Text="{Binding PreviewTitle}"
                                                        Style="{StaticResource CompactSectionTitleTextStyle}"/>
                                            <TextBlock Text="{Binding SelectedPluginContextTitle}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedPluginDescription}"
                                                        Style="{StaticResource SectionBodyTextStyle}"
                                                        Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Top">
                                            <Border Style="{StaticResource SlotBadgeBorderStyle}">
                                                <TextBlock Text="{Binding PreviewHealthBadge}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SlotBrushConverter}" ConverterParameter="Health">
                                                            <Binding Path="PreviewHealthToneKey"/>
                                                            <Binding RelativeSource="{RelativeSource Self}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>

                                            <Border Style="{StaticResource SlotChipBorderStyle}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="{Binding PreviewTypeBadge}"
                                                           Style="{StaticResource SlotValueChipTextStyle}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,10,0,0"
                                            Style="{StaticResource CompactStatusBorderStyle}"
                                            Visibility="Collapsed">
                                        <TextBlock Text="{Binding ValidationSummary}"
                                                   Style="{StaticResource CompactStatusTextStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Label row: left/right layout -->
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Label"
                                           Style="{StaticResource CompactSectionTitleTextStyle}"
                                           VerticalAlignment="Center"/>
                                <ui:TextBox Grid.Column="1"
                                            Text="{Binding Slot.Label, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="Display label"/>
                            </Grid>

                            <!-- Action choice row: left/right layout + unified ComboBox -->
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Validation error banner -->
                                <Border Grid.Row="0"
                                        Margin="0,0,0,8"
                                        Padding="12,10"
                                        Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="{Binding HasActionValidationError, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ActionValidationMessage}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Action label + control -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Action"
                                               Style="{StaticResource CompactSectionTitleTextStyle}"
                                               VerticalAlignment="Center"/>

                                    <!-- Single action: display only -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Slot.ActionLabel}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Multiple actions: unified ComboBox -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableActions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              SelectedValue="{Binding Slot.Action}"
                                              SelectionChanged="ActionComboBox_SelectionChanged"
                                              Visibility="{Binding HasMultipleActions, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Grid>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding HasRequiredParameters, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding RequiredParameters}"
                                              ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                            </StackPanel>
                            <ui:CardExpander Header="Appearance"
                                             IsExpanded="True"
                                             Margin="0,16,0,0"
                                             HorizontalContentAlignment="Stretch"
                                             Visibility="{Binding HasOptionalSettings, Converter={StaticResource BoolToVis}}">
                                <StackPanel Margin="0,4,0,0">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Color"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Border Width="56"
                                                    Height="36"
                                                    CornerRadius="8"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                                    Cursor="Hand"
                                                    ToolTip="Pick color"
                                                    MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown">
                                                <Grid>
                                                    <ui:SymbolIcon Symbol="Drop24"
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Icon"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ui:TextBox Grid.Column="1"
                                                    Text="{Binding Slot.IconKey}"
                                                    Icon="{ui:SymbolIcon Image24}"
                                                    PlaceholderText="e.g. Settings24 or C:\icon.png"/>
                                        <ui:Button Grid.Column="2"
                                                   Icon="{ui:SymbolIcon FolderOpen16}"
                                                   Style="{StaticResource PulsarIconButtonStyle}"
                                                   Click="PickIcon_Click"
                                                   ToolTip="Browse icon file"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Optional"
                                             IsExpanded="False"
                                             Margin="0,10,0,0"
                                             HorizontalContentAlignment="Stretch"
                                             Visibility="{Binding HasOptionalSettings, Converter={StaticResource BoolToVis}}">
                                <StackPanel Margin="0,4,0,0">
                                    <StackPanel Visibility="{Binding HasOptionalParameters, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding OptionalParameters}"
                                                      ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0"
                                                Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Advanced"
                                                   Style="{StaticResource CompactSectionTitleTextStyle}"
                                                   Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding AdvancedParameters}"
                                                      ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>

                        <Border Padding="12,10"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding IsAwaitingPluginSelection, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Select a scenario or switch to Advanced to configure the label, action, required details, and optional settings."
                                         Style="{StaticResource SectionBodyTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
