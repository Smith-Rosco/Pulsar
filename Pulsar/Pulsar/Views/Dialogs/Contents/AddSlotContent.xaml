<UserControl x:Class="Pulsar.Views.Dialogs.Contents.AddSlotContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:models="clr-namespace:Pulsar.Models"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:controls="clr-namespace:Pulsar.Views.Controls"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             MinWidth="760"
             MinHeight="520"
             d:DataContext="{d:DesignInstance Type=viewmodels:AddSlotViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>

            <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompactSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="WorkflowDividerStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Padding" Value="0,0,0,16"/>
            </Style>

            <Style x:Key="PickerItemNameTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PickerSelectedBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="6,1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PickerSelectedBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>



            <Style x:Key="ParameterCardBorderStyle" TargetType="Border">
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style x:Key="ParameterRowBorderStyle" TargetType="Border">
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="Padding" Value="0,8,0,10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasValidationMessage}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Padding" Value="12,10"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ConfigurationExpanderStyle" TargetType="Expander">
                <Setter Property="Margin" Value="0,10,0,0"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>

            <Style x:Key="HeaderStatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="CompactStatusBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CompactStatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasCriticalValidationState}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PickerCategoryButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CategoryBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <TextBlock x:Name="CategoryText"
                                           Text="{TemplateBinding Content}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="CategoryBorder" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                    <Setter TargetName="CategoryBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                    <Setter TargetName="CategoryText" Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PluginTypeCardButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="200"/>
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PickerBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="PickerBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                    <Setter TargetName="PickerBorder" Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="CreateSlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text=" *"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <ui:Button Grid.Column="1"
                                   Width="28"
                                   Height="28"
                                   Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Info24}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   ToolTip="{Binding HelpTooltipText}"
                                   Visibility="{Binding HasHelpContent, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <Border Grid.Row="1">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ParameterRowBorderStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseCompactRowLayout}" Value="False">
                                        <Setter Property="Padding" Value="12,10"/>
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayValue}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SecondaryDisplayValue}"
                                           Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasSecondaryDisplayValue, Converter={StaticResource BoolToVis}}"/>
                                 <TextBlock Text="{Binding ValidationHint}"
                                            Margin="0,5,0,0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Visibility="{Binding HasValidationHint, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding ValidationMessage}"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasValidationMessage, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Content="{Binding SelectorActionLabel}"
                                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                                       Click="SlotParameterPicker_Click"
                                       Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,0,20,0">
            <StackPanel Margin="0,0,0,16">
                <Border Padding="0,0,0,16"
                        Margin="0,0,0,18"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding HeaderText}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>

                            <Border Margin="10,2,0,0"
                                    Style="{StaticResource HeaderStatusBadgeBorderStyle}">
                                <TextBlock Text="{Binding HeaderStatusText}"
                                           Style="{StaticResource HeaderStatusBadgeTextStyle}"/>
                            </Border>
                        </WrapPanel>

                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="332"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Choose behavior"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>
                        <TextBlock Text="{Binding PluginPickerHint}"
                                   Style="{StaticResource SectionBodyTextStyle}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding PluginTypeCategories}"
                                      Visibility="{Binding HasPickerCategories, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PickerCategoryButtonStyle}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding DisplayLabel}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding FilteredPluginTypes}"
                                      Margin="0,4,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PluginTypeCardButtonStyle}"
                                            Command="{Binding DataContext.SelectPluginTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.ToolTip>
                                            <ToolTip Content="{Binding Description}"
                                                     MaxWidth="260"/>
                                        </Button.ToolTip>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="8"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    Margin="0,0,10,0">
                                                <controls:SlotOrb Size="24"
                                                                  Width="24"
                                                                  Height="24"
                                                                  Opacity="1"
                                                                  IsActive="False"
                                                                  IsHitTestVisible="False"
                                                                  ShowActiveGlow="False"
                                                                  IsTransparent="True"
                                                                  IconKey="{Binding IconKey}"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource PickerItemNameTextStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Configure slot"
                                   Style="{StaticResource SectionEyebrowTextStyle}"/>

                        <StackPanel Visibility="{Binding HasSelectedPlugin, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource WorkflowDividerStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <controls:SlotOrb Grid.Column="0"
                                                          Size="34"
                                                          Width="34"
                                                          Height="34"
                                                          Opacity="1"
                                                          IsActive="False"
                                                          IsHitTestVisible="False"
                                                          ShowActiveGlow="False"
                                                          IsTransparent="True"
                                                          IconKey="{Binding Slot.IconKey}"
                                                          CustomFill="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                                          CustomStroke="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"/>

                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0,12,0">
                                            <TextBlock Text="{Binding PreviewTitle}"
                                                        Style="{StaticResource CompactSectionTitleTextStyle}"/>
                                            <TextBlock Text="{Binding SelectedPluginContextTitle}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedPluginDescription}"
                                                        Style="{StaticResource SectionBodyTextStyle}"
                                                        Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Top">
                                            <Border Style="{StaticResource SlotBadgeBorderStyle}">
                                                <TextBlock Text="{Binding PreviewHealthBadge}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource SlotBrushConverter}" ConverterParameter="Health">
                                                            <Binding Path="PreviewHealthToneKey"/>
                                                            <Binding RelativeSource="{RelativeSource Self}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>

                                            <Border Style="{StaticResource SlotChipBorderStyle}"
                                                    Margin="0,6,0,0">
                                                <TextBlock Text="{Binding PreviewTypeBadge}"
                                                           Style="{StaticResource SlotValueChipTextStyle}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,10,0,0"
                                            Style="{StaticResource CompactStatusBorderStyle}"
                                            Visibility="Collapsed">
                                        <TextBlock Text="{Binding ValidationSummary}"
                                                   Style="{StaticResource CompactStatusTextStyle}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="Label"
                                           Style="{StaticResource CompactSectionTitleTextStyle}"
                                           Margin="0,0,0,8"/>
                                <ui:TextBox Text="{Binding Slot.Label, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Display label"/>
                            </StackPanel>

                            <StackPanel x:Name="ActionChoiceSection"
                                        Margin="0,16,0,0">
                                <TextBlock Text="Action choice"
                                            Style="{StaticResource CompactSectionTitleTextStyle}"
                                            Margin="0,0,0,8"/>

                                <Border Margin="0,0,0,10"
                                        Padding="12,10"
                                        Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="{Binding HasActionValidationError, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ActionValidationMessage}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <StackPanel Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding Slot.ActionLabel}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Slot.ActionDescription}"
                                               Margin="0,3,0,0"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding UseRadioActions, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding AvailableActions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,6"
                                                        Margin="0,0,0,2"
                                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <RadioButton Content="{Binding Label}"
                                                                 ToolTip="{Binding Description}"
                                                                 IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                 Checked="ActionRadio_Checked"
                                                                 Tag="{Binding Value}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Visibility="{Binding UseComboActions, Converter={StaticResource BoolToVis}}">
                                    <ComboBox ItemsSource="{Binding AvailableActions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              SelectedValue="{Binding Slot.Action, Mode=OneWay}"
                                              SelectionChanged="ActionComboBox_SelectionChanged"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding HasRequiredParameters, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Required details"
                                           Style="{StaticResource CompactSectionTitleTextStyle}"
                                           Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding RequiredParameters}"
                                              ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                            </StackPanel>

                            <Expander Header="Optional settings"
                                      IsExpanded="False"
                                      Margin="0,16,0,0"
                                      Visibility="{Binding HasOptionalSettings, Converter={StaticResource BoolToVis}}"
                                      Style="{StaticResource ConfigurationExpanderStyle}">
                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel Visibility="{Binding HasOptionalParameters, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Optional details"
                                                   Style="{StaticResource CompactSectionTitleTextStyle}"
                                                   Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding OptionalParameters}"
                                                      ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Appearance"
                                                   Style="{StaticResource CompactSectionTitleTextStyle}"
                                                   Margin="0,0,0,10"/>

                                        <TextBlock Text="Color"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                             <Border Width="56"
                                                     Height="36"
                                                     CornerRadius="8"
                                                     BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                     BorderThickness="1"
                                                     Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                     Cursor="Hand"
                                                     ToolTip="Pick color"
                                                     MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown">
                                                <Grid>
                                                    <Border Width="20"
                                                            Height="20"
                                                            CornerRadius="6"
                                                            Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                            BorderThickness="1"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                    <ui:SymbolIcon Symbol="Drop24"
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                </Grid>
                                             </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="Color is optional polish once the slot behavior feels right."
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>

                                        <TextBlock Text="Icon"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ui:TextBox Grid.Column="0"
                                                        Text="{Binding Slot.IconKey}"
                                                        Icon="{ui:SymbolIcon Image24}"
                                                        PlaceholderText="e.g. Settings24 or C:\icon.png"/>

                                            <ui:Button Grid.Column="1"
                                                       Icon="{ui:SymbolIcon FolderOpen16}"
                                                       Style="{StaticResource PulsarIconButtonStyle}"
                                                       Click="PickIcon_Click"
                                                       ToolTip="Browse icon file"
                                                       Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0"
                                                Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Advanced"
                                                   Style="{StaticResource CompactSectionTitleTextStyle}"
                                                   Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding AdvancedParameters}"
                                                      ItemTemplate="{StaticResource CreateSlotParameterFieldTemplate}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <Border Padding="12,10"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding IsAwaitingPluginSelection, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Select a slot type to configure the label, action, required details, and optional settings."
                                        Style="{StaticResource SectionBodyTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
