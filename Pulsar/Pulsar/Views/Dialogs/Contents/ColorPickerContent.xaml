<UserControl x:Class="Pulsar.Views.Dialogs.Contents.ColorPickerContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:lex="clr-namespace:Pulsar.Core.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ColorPickerViewModel}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Preview & Hex -->
            <RowDefinition Height="Auto"/> <!-- Sliders -->
            <RowDefinition Height="*"/>    <!-- Presets -->
        </Grid.RowDefinitions>

        <!-- Preview & Hex Input -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Preview Box -->
            <Border Width="60" Height="60" CornerRadius="8" 
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                    Margin="0,0,16,0">
                <Border.Background>
                    <SolidColorBrush Color="{Binding CurrentColor}"/>
                </Border.Background>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{lex:Locale Dialog.ColorPicker.HexCode}" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <ui:TextBox Text="{Binding HexInput, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{lex:Locale Dialog.ColorPicker.HexPlaceholder}"
                            Icon="{ui:SymbolIcon Color24}"/>
                <TextBlock Text="{lex:Locale Dialog.ColorPicker.InvalidHex}" 
                           Foreground="{DynamicResource PaletteRedBrush}" 
                           FontSize="12" 
                           Margin="0,4,0,0"
                           Visibility="{Binding IsHexError, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>

        <!-- RGB Sliders -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{lex:Locale Dialog.ColorPicker.R}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FF5555"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding R}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding R}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{lex:Locale Dialog.ColorPicker.G}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#55FF55"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding G}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding G}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{lex:Locale Dialog.ColorPicker.B}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#5555FF"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding B}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding B}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <!-- Presets -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" 
                       Text="{lex:Locale Dialog.ColorPicker.Presets}" 
                       Margin="0,0,0,8" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Presets}" x:Name="PresetsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="32" Height="32" Margin="0,0,8,8" 
                                    Command="{Binding Tag.SelectPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Name}">
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border CornerRadius="16" Background="{Binding Brush}" BorderThickness="1" BorderBrush="#30000000"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
