<UserControl x:Class="Pulsar.Views.Dialogs.Contents.ProcessBlacklistContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             d:DataContext="{d:DesignInstance Type=viewmodels:ProcessBlacklistViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Select processes to exclude from the window switcher:" 
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"
                   Opacity="0.8"/>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Processes}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon with running indicator -->
                        <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4">
                                <ui:SymbolIcon Symbol="AppGeneric24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <Image Source="{Binding Icon}" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <!-- Running indicator (green dot) -->
                            <Ellipse Width="8" Height="8" 
                                     Fill="LimeGreen" 
                                     HorizontalAlignment="Right" 
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,-2,-2">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>

                        <!-- Process name and display name -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" 
                                       FontWeight="SemiBold" 
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ProcessName}" 
                                       FontSize="11" 
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Status text -->
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding StatusText}" 
                                   FontSize="11" 
                                   Opacity="0.7" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <!-- Blacklist checkbox -->
                        <CheckBox Grid.Column="3" 
                                  IsChecked="{Binding IsBlacklisted}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Grid Grid.Row="1" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
        </Grid>
    </Grid>
</UserControl>
