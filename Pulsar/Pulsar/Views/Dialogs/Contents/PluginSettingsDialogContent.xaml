<UserControl x:Class="Pulsar.Views.Dialogs.Contents.PluginSettingsDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
             xmlns:ts="clr-namespace:Pulsar.Views.TemplateSelectors"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="550">
    <UserControl.Resources>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate x:Key="BooleanSettingTemplate" DataType="{x:Type vm:BooleanSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding BoolValue, Mode=TwoWay}"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="StringSettingTemplate" DataType="{x:Type vm:StringSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:TextBox Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Width="220"
                            HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="SelectionSettingTemplate" DataType="{x:Type vm:SelectionSettingViewModel}">
             <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox ItemsSource="{Binding Options}" 
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          Width="220"
                          HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="PathSettingTemplate" DataType="{x:Type vm:PathSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" 
                                Text="{Binding PathValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Enter or browse path..."
                                HorizontalAlignment="Right"/>
                    <ui:Button Grid.Column="1"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               ToolTip="Browse"
                               Appearance="Secondary"
                               Margin="4,0,0,0"
                               Tag="{Binding}"
                               Click="BrowsePathButton_Click"/>
                </Grid>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="IntegerSettingTemplate" DataType="{x:Type vm:IntegerSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:NumberBox Value="{Binding IntValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SpinButtonPlacementMode="Compact"
                              Width="140"
                              HorizontalAlignment="Right"
                              Minimum="{Binding Definition.MinValue}"
                              Maximum="{Binding Definition.MaxValue}"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="SecretSettingTemplate" DataType="{x:Type vm:SecretSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:PasswordBox Password="{Binding SecretValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="220"
                                HorizontalAlignment="Right"
                                PlaceholderText="Enter secret value..."/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="MultiSelectSettingTemplate" DataType="{x:Type vm:MultiSelectSettingViewModel}">
            <ui:CardControl Margin="0,4">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="#dc3545"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasValidation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Width="260">
                    <TextBlock Text="Click to toggle selection:" 
                               FontSize="11" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding OptionItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Content="{Binding Name}"
                                              Margin="0,2,4,2"
                                              Padding="8,4"
                                              FontSize="11"
                                              Cursor="Hand">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorAccentBackground3}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Or enter manually:" 
                               FontSize="11" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,8,0,2"/>
                    <ui:TextBox Text="{Binding CommaSeparatedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Comma-separated values..."/>
                </StackPanel>
            </ui:CardControl>
        </DataTemplate>

        <ts:PluginSettingTemplateSelector x:Key="SettingSelector"
                                          BooleanTemplate="{StaticResource BooleanSettingTemplate}"
                                          StringTemplate="{StaticResource StringSettingTemplate}"
                                          SelectionTemplate="{StaticResource SelectionSettingTemplate}"
                                          PathTemplate="{StaticResource PathSettingTemplate}"
                                          IntegerTemplate="{StaticResource IntegerSettingTemplate}"
                                          SecretTemplate="{StaticResource SecretSettingTemplate}"
                                          MultiSelectTemplate="{StaticResource MultiSelectSettingTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding PluginName}" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding PluginDescription}" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Settings}"
                          ItemTemplateSelector="{StaticResource SettingSelector}"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="Reset to Defaults"
                       Appearance="Secondary"
                       Command="{Binding ResetToDefaultsCommand}"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Cancel"
                       Appearance="Secondary"
                       Command="{Binding CancelCommand}"
                       Margin="0,0,8,0"/>
            <ui:Button Content="Save"
                       Appearance="Primary"
                       Command="{Binding SaveCommand}"
                       IsEnabled="{Binding CanSave}"/>
        </StackPanel>
    </Grid>
</UserControl>
