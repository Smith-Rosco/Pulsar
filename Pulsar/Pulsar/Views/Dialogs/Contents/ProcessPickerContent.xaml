<UserControl x:Class="Pulsar.Views.Dialogs.Contents.ProcessPickerContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TextBox Grid.Row="0" x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                    PlaceholderText="Search running apps..." 
                    Icon="{ui:SymbolIcon Search24}"
                    Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredProcesses}" 
                 SelectedItem="{Binding SelectedProcess}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="8"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="32" Height="32" Margin="0,0,10,0">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4">
                                <ui:SymbolIcon Symbol="AppGeneric24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>
                            <Image RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="{Binding AppIcon}"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AppIcon}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" 
                                       FontWeight="SemiBold" 
                                       TextTrimming="CharacterEllipsis"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ProcessName}" 
                                           FontSize="11" Opacity="0.7"/>

                                <TextBlock Text=" • " FontSize="11" Opacity="0.5"/>

                                <TextBlock Text="{Binding ExePath}" 
                                           FontSize="11" Opacity="0.5" 
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
        </Grid>
    </Grid>
</UserControl>
