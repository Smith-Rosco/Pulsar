<UserControl x:Class="Pulsar.Views.Dialogs.Contents.SlotConfigurationDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:models="clr-namespace:Pulsar.Models"
             xmlns:controls="clr-namespace:Pulsar.Views.Controls"
             mc:Ignorable="d"
             MinWidth="760"
             MinHeight="520"
             d:DataContext="{d:DesignInstance Type=viewmodels:SlotConfigurationDialogViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="BoolToVisInverse"/>
            <converters:StringToBoolConverter x:Key="StringToBool"/>

            <Style x:Key="SectionEyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CompactSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="CompactStatusBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasBlockingIssue}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CompactStatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding HasBlockingIssue}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <DataTemplate x:Key="SlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Label}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" *"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Width="26"
                                   Height="26"
                                   Padding="5"
                                   Margin="0,0,6,0"
                                   Icon="{ui:SymbolIcon FolderOpen16}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   ToolTip="Browse"
                                   Click="SlotParameterPicker_Click"
                                   Tag="{Binding}"
                                   Visibility="{Binding HasPicker, Converter={StaticResource BoolToVis}}"/>

                        <ui:ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding Value, Mode=TwoWay, Converter={StaticResource StringToBool}}"
                                         Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVis}}"/>

                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{Binding Placeholder}"
                                    Visibility="{Binding IsBoolType, Converter={StaticResource BoolToVisInverse}}"/>
                    </Grid>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,0,20,0">
            <StackPanel Margin="0,0,0,16">
                <Border Padding="0,0,0,16"
                        Margin="0,0,0,18"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="332"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding HeaderText}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <TextBlock Text="{Binding HeaderDescription}"
                                       Style="{StaticResource SectionBodyTextStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Style="{StaticResource CompactStatusBorderStyle}"
                                Visibility="{Binding HasValidationSummary, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ValidationSummary}"
                                       Style="{StaticResource CompactStatusTextStyle}"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel>
                    <TextBlock Text="Behavior"
                               Style="{StaticResource SectionEyebrowTextStyle}"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Action"
                                   Style="{StaticResource CompactSectionTitleTextStyle}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Slot.ActionLabel}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding Slot.ActionDescription}"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableActions}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding Slot.Action}"
                                  SelectionChanged="ActionComboBox_SelectionChanged"
                                  Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVisInverse}}"/>
                    </Grid>

                    <StackPanel Visibility="{Binding HasRequiredParameters, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding RequiredParameters}"
                                      ItemTemplate="{StaticResource SlotParameterFieldTemplate}"/>
                    </StackPanel>

                    <ui:CardExpander Header="Appearance"
                                     IsExpanded="True"
                                     Margin="0,16,0,0"
                                     HorizontalContentAlignment="Stretch">
                        <StackPanel Margin="0,4,0,0">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Label"
                                           Style="{StaticResource CompactSectionTitleTextStyle}"
                                           VerticalAlignment="Center"/>
                                <ui:TextBox Grid.Column="1"
                                            Text="{Binding Slot.Label, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="Display label"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Color"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="56"
                                            Height="36"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                            Cursor="Hand"
                                            ToolTip="Pick color"
                                            MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown">
                                        <ui:SymbolIcon Symbol="Drop24"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Icon"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ui:Button Grid.Column="1"
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Style="{StaticResource PulsarIconButtonStyle}"
                                           Click="PickIcon_Click"
                                           ToolTip="Browse icon file"
                                           Margin="0,0,8,0"/>
                                <ui:TextBox Grid.Column="2"
                                            Text="{Binding Slot.IconKey}"
                                            Icon="{ui:SymbolIcon Image24}"
                                            PlaceholderText="e.g. Settings24 or C:\icon.png"/>
                            </Grid>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="Optional"
                                     IsExpanded="False"
                                     Margin="0,10,0,0"
                                     HorizontalContentAlignment="Stretch"
                                     Visibility="{Binding HasOptionalParameters, Converter={StaticResource BoolToVis}}">
                        <StackPanel Margin="0,4,0,0">
                            <ItemsControl ItemsSource="{Binding OptionalParameters}"
                                          ItemTemplate="{StaticResource SlotParameterFieldTemplate}"/>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="Advanced"
                                     IsExpanded="False"
                                     Margin="0,10,0,0"
                                     HorizontalContentAlignment="Stretch"
                                     Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVis}}">
                        <StackPanel Margin="0,4,0,0">
                            <ItemsControl ItemsSource="{Binding AdvancedParameters}"
                                          ItemTemplate="{StaticResource SlotParameterFieldTemplate}"/>
                        </StackPanel>
                    </ui:CardExpander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
