<UserControl x:Class="Pulsar.Views.Dialogs.Contents.SlotConfigurationDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:models="clr-namespace:Pulsar.Models"
             xmlns:controls="clr-namespace:Pulsar.Views.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:SlotConfigurationDialogViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>

            <DataTemplate x:Key="DialogSlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text=" *"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                           Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                       Width="28"
                                       Height="28"
                                       Margin="8,0,0,0"
                                       Icon="{ui:SymbolIcon Info24}"
                                       Style="{StaticResource PulsarIconButtonStyle}"
                                       ToolTip="{Binding HelpTooltipText}"
                                       Visibility="{Binding HasHelpContent, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <TextBlock Text="{Binding Description}"
                                   Margin="0,0,0,8"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="{Binding Placeholder}"/>

                            <ui:Button Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Content="{Binding PickerButtonLabel}"
                                       Click="SlotParameterPicker_Click"
                                       Tag="{Binding}"
                                       Visibility="{Binding HasPicker, Converter={StaticResource BoolToVis}}"
                                       Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="360"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10"
                Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="{Binding HeaderText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding HeaderDescription}"
                           Margin="0,2,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SlotOrbContainerStyle}"
                        Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}">
                    <controls:SlotOrb Size="24"
                                       Width="24"
                                       Height="24"
                                       Margin="4"
                                       IsActive="False"
                                       IsHitTestVisible="False"
                                       ShowActiveGlow="False"
                                       IsTransparent="True"
                                       IconKey="{Binding Slot.IconKey}"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding PreviewTitle}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Border Style="{StaticResource SlotChipBorderStyle}">
                            <TextBlock Text="{Binding PreviewTypeBadge}"
                                       Style="{StaticResource SlotValueChipTextStyle}"
                                       FontSize="9"
                                       Foreground="{Binding Slot.TypeToneKey, Converter={StaticResource SlotBrushConverter}, ConverterParameter=Type}"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding PreviewActionText}"
                               Margin="0,2,0,0"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource SlotBadgeBorderStyle}">
                    <TextBlock Text="{Binding PreviewHealthBadge}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{Binding PreviewHealthToneKey, Converter={StaticResource SlotBrushConverter}, ConverterParameter=Health}"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Behavior"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,10"/>

                        <StackPanel Visibility="{Binding HasSingleAction, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Slot.ActionLabel}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding Slot.ActionDescription}"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding UseRadioActions, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding AvailableActions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,8"
                                                Margin="0,0,0,8">
                                            <RadioButton Content="{Binding Label}"
                                                         ToolTip="{Binding Description}"
                                                         IsChecked="{Binding IsSelected}"
                                                         GroupName="EditSlotActionGroup"
                                                         Click="ActionRadio_Click"
                                                         Tag="{Binding Value}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Visibility="{Binding UseComboActions, Converter={StaticResource BoolToVis}}">
                            <ComboBox ItemsSource="{Binding AvailableActions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      SelectedValue="{Binding Slot.Action}"
                                      SelectionChanged="ActionComboBox_SelectionChanged"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,8"
                        Visibility="{Binding HasValidationSummary, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ValidationSeverity}" Value="Error">
                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ValidationSummary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Border>

                <StackPanel Visibility="{Binding HasRequiredParameters, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,4">
                    <TextBlock Text="Required details"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RequiredParameters}"
                                  ItemTemplate="{StaticResource DialogSlotParameterFieldTemplate}"/>
                </StackPanel>

                <StackPanel Visibility="{Binding HasOptionalParameters, Converter={StaticResource BoolToVis}}"
                            Margin="0,8,0,4">
                    <Expander Header="Optional details" IsExpanded="False">
                        <ItemsControl Margin="0,10,0,0"
                                      ItemsSource="{Binding OptionalParameters}"
                                      ItemTemplate="{StaticResource DialogSlotParameterFieldTemplate}"/>
                    </Expander>
                </StackPanel>

                <StackPanel Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVis}}"
                            Margin="0,8,0,12">
                    <Expander Header="Advanced" IsExpanded="False">
                        <ItemsControl Margin="0,10,0,0"
                                      ItemsSource="{Binding AdvancedParameters}"
                                      ItemTemplate="{StaticResource DialogSlotParameterFieldTemplate}"/>
                    </Expander>
                </StackPanel>

                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Appearance"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Label"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <ui:TextBox Text="{Binding Slot.Label, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Display label"
                                    Margin="0,0,0,12"/>

                        <TextBlock Text="Color"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="56"
                                    Height="36"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1"
                                    Background="{Binding Slot.Color, Converter={StaticResource HexToBrush}}"
                                    Cursor="Hand"
                                    ToolTip="Pick color"
                                    MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown">
                                <ui:SymbolIcon Symbol="Drop24"
                                               FontSize="16"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Text="Adjust the ring color only when the default no longer fits the slot's role."
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <TextBlock Text="Icon"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding Slot.IconKey}"
                                        Icon="{ui:SymbolIcon Image24}"
                                        PlaceholderText="e.g. Settings24 or C:\icon.png"/>

                            <ui:Button Grid.Column="1"
                                       Icon="{ui:SymbolIcon FolderOpen16}"
                                       Style="{StaticResource PulsarIconButtonStyle}"
                                       Click="PickIcon_Click"
                                       ToolTip="Browse icon file"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Summary"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding SummaryTokens}"
                                      Visibility="{Binding HasSummaryTokens, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SlotSummaryTokenBorderStyle}">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource SlotSummaryTokenTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Expander Grid.Row="3"
                  Header="More actions"
                  Margin="0,8,0,0"
                  HorizontalAlignment="Stretch">
            <Border Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                    BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,10"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Danger zone"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="Delete this slot permanently when it is no longer needed."
                                   FontSize="11"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ui:Button Grid.Column="1"
                               Content="Delete Slot"
                               Icon="{ui:SymbolIcon Delete24}"
                               Style="{StaticResource PulsarDangerButtonStyle}"
                               Click="RemoveSlot_Click"
                               ToolTip="Permanently remove this slot"
                               Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</UserControl>
