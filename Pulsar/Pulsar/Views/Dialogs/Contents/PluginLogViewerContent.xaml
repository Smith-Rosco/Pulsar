<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="760">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
            <converters:LogLevelToColorConverter x:Key="LogLevelToColorConverter"/>
            <converters:UtcToLocalTimeConverter x:Key="UtcToLocalTimeConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding LevelOptions}"
                      SelectedItem="{Binding SelectedLevelOption, Mode=TwoWay}"
                      DisplayMemberPath="Label"
                      Margin="0,0,12,0"/>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding TimeRangeOptions}"
                      SelectedItem="{Binding SelectedTimeRangeOption, Mode=TwoWay}"
                      DisplayMemberPath="Label"
                      Margin="0,0,12,0"/>

            <ui:TextBox Grid.Column="2"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search logs..."
                        Icon="{ui:SymbolIcon Search24}"
                        Margin="0,0,12,0"/>

            <ui:Button Grid.Column="3"
                       Content="Export"
                       Command="{Binding ExportLogsCommand}"
                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                       Icon="{ui:SymbolIcon ArrowDownload24}"/>
        </Grid>

        <!-- Log list -->
        <Border Grid.Row="1"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <ListView ItemsSource="{Binding Logs}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, Converter={StaticResource UtcToLocalTimeConverter}}"
                                           FontSize="11"
                                           Opacity="0.7"
                                           Margin="0,0,12,0"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Level}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                                           Margin="0,0,12,0"/>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               FontSize="12"/>

                                    <TextBlock Text="{Binding Exception}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.6"
                                               Visibility="{Binding Exception, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Background="Transparent">
                    <ui:ProgressRing IsIndeterminate="True" Width="36" Height="36"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="Load More"
                       Command="{Binding LoadMoreCommand}"
                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                       Icon="{ui:SymbolIcon MoreHorizontal24}"/>
        </StackPanel>
    </Grid>
</UserControl>
