<UserControl x:Class="Pulsar.Views.Dialogs.Contents.FirstLaunchSetupWizardContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:converters="clr-namespace:Pulsar.Views.Converters"
             xmlns:coreConverters="clr-namespace:Pulsar.Core.Converters"
             mc:Ignorable="d"
             MinWidth="660"
             MinHeight="440"
             d:DataContext="{d:DesignInstance Type=viewmodels:FirstLaunchSetupWizardViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <coreConverters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <coreConverters:StringPathToImageSourceConverter x:Key="PathToImageConverter"/>
            <coreConverters:IsImagePathConverter x:Key="IsImagePathConverter"/>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="14"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="CardSelectionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SelectableCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Language picker -->
        <Border Grid.Row="0"
                Padding="8,5"
                Margin="0,0,0,12"
                CornerRadius="6"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🌐" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding SupportedLanguages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          FontSize="11"
                          MinWidth="100"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,12">

                <!-- Welcome -->
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="0,0,0,16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- Error -->
                <Border Padding="10,8"
                        Margin="0,0,0,10"
                        CornerRadius="8"
                        Background="#FDE7E9"
                        BorderBrush="#D13438"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#D13438"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" TextWrapping="Wrap" FontSize="12" Foreground="#D13438" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Scenario Cards -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{Binding DataContext.UsageProfileLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ItemsControl ItemsSource="{Binding Scenarios}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource CardSelectionButtonStyle}"
                                            Command="{Binding DataContext.SelectScenarioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Style="{StaticResource SelectableCardBorderStyle}"
                                                Width="190" Margin="0,0,12,0" Padding="14,14">
                                            <StackPanel>
                                                <Border Width="36" Height="36"
                                                        CornerRadius="10"
                                                        HorizontalAlignment="Center"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <TextBlock Text="{Binding IconKey}"
                                                                   FontFamily="Segoe UI, Segoe UI Emoji"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IconKey, Converter={StaticResource IsImagePathConverter}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Image Source="{Binding IconKey, Converter={StaticResource PathToImageConverter}}"
                                                               Width="20" Height="20"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Legacy Usage Profile (hidden) -->
                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,14"
                        Visibility="{Binding IsUsingScenarios, Converter={StaticResource InverseBoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding UsageProfileLabel}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ItemsControl ItemsSource="{Binding UsageProfiles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource CardSelectionButtonStyle}"
                                            Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Style="{StaticResource SelectableCardBorderStyle}" Width="200" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
