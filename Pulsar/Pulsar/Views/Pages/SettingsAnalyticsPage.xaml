<Page x:Class="Pulsar.Views.Pages.SettingsAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      xmlns:lex="clr-namespace:Pulsar.Core.Localization"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{lex:Locale Settings.Analytics.Title}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="{lex:Locale Settings.Analytics.Title}"
                                     Description="{lex:Locale Settings.Analytics.Description}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,20,0" MaxWidth="720" HorizontalAlignment="Left">

                <!-- Loading Indicator -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,40,0,0">
                    <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="{lex:Locale Settings.Analytics.Loading}"
                               FontSize="13" Margin="0,12,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- No Data Message -->
                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Style>
                        <Style TargetType="ui:CardControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding HasData}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:CardControl.Style>
                    <StackPanel HorizontalAlignment="Center" Margin="0,24">
                        <ui:SymbolIcon Symbol="DataPie24" FontSize="36"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{lex:Locale Settings.Analytics.NoData}"
                                   FontSize="13" Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="360"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- Error State -->
                <ui:CardControl Margin="0,0,0,16"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,16">
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="36"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="13" Margin="0,12,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="360"/>
                        <ui:Button Content="{lex:Locale Settings.Analytics.Refresh}"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Command="{Binding RefreshCommand}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- Summary Dashboard -->
                <Grid Margin="0,0,0,16"
                      Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:CardControl Grid.Column="0" Padding="14,12" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalOverallExecutions}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.SummaryTotalExec}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:CardControl>

                    <ui:CardControl Grid.Column="1" Padding="14,12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ActivePluginCount}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorAccentBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.SummaryActivePlugins}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:CardControl>

                    <ui:CardControl Grid.Column="2" Padding="14,12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalTodayExecutions}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.SummaryToday}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:CardControl>

                    <ui:CardControl Grid.Column="3" Padding="14,12" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalWeekExecutions}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.SummaryWeek}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:CardControl>
                </Grid>

                <!-- Slot Usage Heatmap -->
                <ui:CardControl Margin="0,0,0,16"
                                Visibility="{Binding HasHeatmap, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DataPie24" Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.SlotHeatmap}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ItemsControl ItemsSource="{Binding SlotHeatmap}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontWeight="Medium"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                    <Grid Grid.Column="1" Margin="10,0">
                                        <Border Height="20"
                                                CornerRadius="4"
                                                Background="{DynamicResource ControlFillColorDisabledBrush}">
                                            <Border Width="{Binding BarWidth, FallbackValue=0}"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="4"
                                                    Background="{DynamicResource SystemFillColorAccentBrush}"
                                                    MinWidth="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TotalExecutions}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Column="2"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               MinWidth="130"
                                               TextAlignment="Right">
                                        <Run Text="{Binding TotalExecutions, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{lex:Locale Settings.Analytics.Executions}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding PluginCount, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{lex:Locale Settings.Analytics.Plugins}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ui:CardControl>

                <!-- Hourly Usage Heatmap -->
                <ui:CardControl Margin="0,0,0,16"
                                Visibility="{Binding HasHourlyHeatmap, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DataTrending24" Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.Title}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ItemsControl ItemsSource="{Binding HourlyHeatmap}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                    <Grid Grid.Column="1" Margin="8,0">
                                        <Border Height="16"
                                                CornerRadius="3"
                                                Background="{DynamicResource ControlFillColorDisabledBrush}">
                                            <Border Width="{Binding BarWidth, FallbackValue=0}"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="3"
                                                    Background="{DynamicResource SystemFillColorAccentBrush}"
                                                    MinWidth="2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TotalExecutions}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Column="2"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               MinWidth="60"
                                               TextAlignment="Right">
                                        <Run Text="{Binding TotalExecutions, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{lex:Locale Settings.Analytics.Executions}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ui:CardControl>

                <!-- Filter Row -->
                <Grid Margin="0,0,0,12"
                      Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{lex:Locale Settings.Analytics.FilterAllTime}"
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" MinWidth="140"
                              SelectedIndex="{Binding TimeRange}">
                        <ComboBoxItem Content="{lex:Locale Settings.Analytics.FilterAllTime}"/>
                        <ComboBoxItem Content="{lex:Locale Settings.Analytics.FilterToday}"/>
                        <ComboBoxItem Content="{lex:Locale Settings.Analytics.FilterThisWeek}"/>
                        <ComboBoxItem Content="{lex:Locale Settings.Analytics.FilterThisMonth}"/>
                    </ComboBox>
                </Grid>

                <!-- Sort Column Headers -->
                <Grid Margin="14,0,14,4"
                      Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Width="32"/>
                    <ui:Button Grid.Column="1" Style="{StaticResource PulsarSecondaryButtonStyle}"
                             Command="{Binding SetSortCommand}" CommandParameter="Executions"
                             HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"
                             Content="{lex:Locale Settings.Analytics.SortByExecutions}"/>
                    <ui:Button Grid.Column="2" Style="{StaticResource PulsarSecondaryButtonStyle}"
                             Command="{Binding SetSortCommand}" CommandParameter="SuccessRate"
                             HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"
                             Content="{lex:Locale Settings.Analytics.SortBySuccessRate}"/>
                    <ui:Button Grid.Column="3" Style="{StaticResource PulsarSecondaryButtonStyle}"
                             Command="{Binding SetSortCommand}" CommandParameter="Duration"
                             HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"
                             Content="{lex:Locale Settings.Analytics.SortByDuration}"/>
                    <ui:Button Grid.Column="4" Style="{StaticResource PulsarSecondaryButtonStyle}"
                             Command="{Binding SetSortCommand}" CommandParameter="LastUsed"
                             HorizontalAlignment="Left" FontSize="11" FontWeight="SemiBold"
                             Content="{lex:Locale Settings.Analytics.SortByLastUsed}"/>
                </Grid>

                <!-- Usage Stats List -->
                <ItemsControl ItemsSource="{Binding MostUsedPlugins}"
                              Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardControl Margin="0,0,0,10" Padding="16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Rank Badge -->
                                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                            Width="32" Height="32" CornerRadius="8"
                                            Margin="0,0,14,0" VerticalAlignment="Center"
                                            Background="{DynamicResource ControlFillColorDisabledBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTopThree}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding RankLabel}"
                                                   FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTopThree}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Plugin Name + Last Used -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Margin="8,0,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding PluginId, StringFormat='({0})'}"/>
                                        <TextBlock Margin="12,0,0,0"
                                                   Text="{Binding LastUsedFormatted, StringFormat='{}{0}'}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Metrics Row -->
                                    <UniformGrid Grid.Row="1" Grid.Column="1" Columns="3" Margin="0,6,0,2">

                                        <!-- Executions -->
                                        <StackPanel>
                                            <TextBlock Text="{Binding TotalFormatted}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{lex:Locale Settings.Analytics.Executions}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>

                                        <!-- Success Rate -->
                                        <StackPanel>
                                            <TextBlock FontSize="20" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SuccessRateColor}" Value="Orange">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorAttentionBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SuccessRateColor}" Value="Red">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{Binding SuccessRate, StringFormat='{}{0:F0}'}"/><Run Text="%"/>
                                            </TextBlock>
                                            <TextBlock Text="{lex:Locale Settings.Analytics.SuccessRate}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>

                                        <!-- Avg Duration -->
                                        <StackPanel>
                                            <TextBlock Text="{Binding DurationFormatted}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{lex:Locale Settings.Analytics.AvgDuration}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- Bottom Row: Slot + Mode Summary + Sparkline -->
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding SlotBreakdown}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{Binding ModeSummary}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="12,0,0,0"/>
                                        <ItemsControl ItemsSource="{Binding TrendData}" Margin="16,0,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="4" Height="14" CornerRadius="1" Margin="1,0"
                                                            Background="{DynamicResource ControlFillColorDisabledBrush}"
                                                            VerticalAlignment="Bottom">
                                                        <Border Width="4"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Bottom"
                                                                CornerRadius="1"
                                                                Background="{DynamicResource SystemFillColorAccentBrush}"
                                                                Height="{Binding BarHeight, FallbackValue=0}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </ui:CardControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recommendations Section -->
                <ui:CardControl Margin="0,12,0,8"
                                Visibility="{Binding HasRecommendations, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Lightbulb16" Margin="0,0,8,0"/>
                            <TextBlock Text="{lex:Locale Settings.Analytics.Recommendations}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="10,8" CornerRadius="6"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol" Value="Info24"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorAccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Symbol" Value="Warning24"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorAttentionBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                            <Setter Property="Symbol" Value="ErrorCircle24"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PluginName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PluginName}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PluginName}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                            <ui:Button Content="{lex:Locale Settings.Analytics.DisablePlugin}"
                                                       Command="{Binding DataContext.DisablePluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding PluginId}"
                                                       FontSize="11" Margin="4,0">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource PulsarDangerButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="ViewLogs">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                            <ui:Button Content="{lex:Locale Settings.Analytics.ViewLogs}"
                                                       Command="{Binding DataContext.ViewLogsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding PluginId}"
                                                       FontSize="11">
                                                <ui:Button.Style>
                                                    <Style TargetType="ui:Button" BasedOn="{StaticResource PulsarSecondaryButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionCommand}" Value="DisablePlugin">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ui:CardControl>

                <!-- Action Buttons Row -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,24">
                    <ui:Button Content="{lex:Locale Settings.Analytics.Refresh}"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Command="{Binding RefreshCommand}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               HorizontalAlignment="Left"/>
                    <ui:Button Content="{lex:Locale Settings.Analytics.ExportCsv}"
                               Icon="{ui:SymbolIcon Save24}"
