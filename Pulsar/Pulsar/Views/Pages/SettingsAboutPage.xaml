<Page x:Class="Pulsar.Views.Pages.SettingsAboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="About">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="About"
                                     Description="Application information and system details"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,20,0" MaxWidth="700" HorizontalAlignment="Left">
                
                <!-- App Identity Card -->
                <ui:CardControl Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- App Icon (Brand Lettermark) -->
                        <Border Grid.Column="0" 
                                Width="80" 
                                Height="80" 
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Margin="0,0,20,0">
                            <Image Width="52"
                                   Height="52"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="pack://application:,,,/Pulsar;component/Assets/Brand/lettermark.png"
                                   Stretch="Uniform" />
                        </Border>

                        <!-- App Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Image Height="26"
                                   Margin="0,0,0,6"
                                   HorizontalAlignment="Left"
                                   Source="pack://application:,,,/Pulsar;component/Assets/Brand/wordmark.png"
                                   Stretch="Uniform" />
                            <TextBlock Text="{Binding AppVersion}" 
                                       FontSize="14" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding AppDescription}" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxWidth="500"
                                       HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </ui:CardControl>

                <!-- Quick Actions -->
                <ui:CardExpander Icon="Link24" Header="Links" Margin="0,0,0,12" IsExpanded="True">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="GitHub Repository" FontWeight="Medium"/>
                                <TextBlock Text="View source code and contribute" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" 
                                       Content="Open"
                                       Icon="{ui:SymbolIcon Open24}"
                                       Command="{Binding OpenGitHubCommand}"
                                       Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                        </Grid>

                        <Separator Margin="0,8"/>

                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Documentation" FontWeight="Medium"/>
                                <TextBlock Text="Learn how to use Pulsar" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" 
                                       Content="Open"
                                       Icon="{ui:SymbolIcon Book24}"
                                       Command="{Binding OpenDocumentationCommand}"
                                       Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                        </Grid>

                        <Separator Margin="0,8"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="License" FontWeight="Medium"/>
                                <TextBlock Text="View license information" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" 
                                       Content="Open"
                                       Icon="{ui:SymbolIcon Document24}"
                                       Command="{Binding OpenLicenseCommand}"
                                       Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- System Information -->
                <ui:CardExpander Icon="Info24" Header="System Information" Margin="0,0,0,12" IsExpanded="False">
                    <StackPanel>
                        <!-- Framework -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Framework" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       FontSize="12"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Framework}" 
                                       FontWeight="Medium"
                                       FontSize="12"/>
                        </Grid>

                        <!-- Architecture -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Architecture" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       FontSize="12"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Architecture}" 
                                       FontWeight="Medium"
                                       FontSize="12"/>
                        </Grid>

                        <!-- Build Configuration -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Build" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       FontSize="12"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding BuildConfiguration}" 
                                       FontWeight="Medium"
                                       FontSize="12"/>
                        </Grid>

                        <!-- Copyright -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Copyright" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       FontSize="12"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Copyright}" 
                                       FontWeight="Medium"
                                       FontSize="12"/>
                        </Grid>

                        <Separator Margin="0,16"/>

                        <!-- Copy System Info Button -->
                        <ui:Button Content="Copy System Information"
                                   Icon="{ui:SymbolIcon Copy24}"
                                   Command="{Binding CopySystemInfoCommand}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   HorizontalAlignment="Left"/>
                    </StackPanel>
                </ui:CardExpander>

                <!-- Credits -->
                <ui:CardExpander Icon="People24" Header="Credits" Margin="0,0,0,12" IsExpanded="False">
                    <StackPanel>
                        <TextBlock Text="Built with" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="•" Margin="0,0,8,0" FontSize="12"/>
                            <TextBlock Text="WPF-UI" FontWeight="Medium" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="- Modern WPF controls" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="•" Margin="0,0,8,0" FontSize="12"/>
                            <TextBlock Text="CommunityToolkit.Mvvm" FontWeight="Medium" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="- MVVM framework" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="•" Margin="0,0,8,0" FontSize="12"/>
                            <TextBlock Text="Serilog" FontWeight="Medium" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="- Structured logging" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="•" Margin="0,0,8,0" FontSize="12"/>
                            <TextBlock Text="Tomlyn" FontWeight="Medium" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="- TOML configuration parser" 
                                       FontSize="12" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
