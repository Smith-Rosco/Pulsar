<Page x:Class="Pulsar.Views.Pages.SettingsGeneralPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels"
      xmlns:models="clr-namespace:Pulsar.Models"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="General">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="General"
                                     Description="Configure application behavior and appearance">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Open App Logs"
                               Icon="{ui:SymbolIcon DocumentText24}"
                               Command="{Binding OpenLogsFolderCommand}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Margin="0,0,8,0"/>
                    <ui:Button Content="Open Plugin Logs"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               Command="{Binding OpenPluginLogsFolderCommand}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Margin="0,0,8,0"/>
                    <ui:Button Content="Reset to Defaults"
                               Icon="{ui:SymbolIcon ArrowReset24}"
                               Command="{Binding ResetConfigCommand}"
                               Style="{StaticResource PulsarDangerButtonStyle}"/>
                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding GeneralSettings}" Margin="0,0,20,0">
                
                <!-- Appearance Section -->
                <ui:CardExpander Icon="Color24" Header="Appearance" Margin="0,0,0,12" IsExpanded="False">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Launcher Theme" FontWeight="Medium"/>
                                <TextBlock Text="Visual style of the radial menu" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="140"
                                      SelectedValue="{Binding DataContext.LauncherTheme, RelativeSource={RelativeSource AncestorType=Page}}" 
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="Dark"/>
                                <ComboBoxItem Content="Light"/>
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Settings Theme" FontWeight="Medium"/>
                                <TextBlock Text="Visual style of this configuration window" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Width="140"
                                      SelectedValue="{Binding DataContext.SettingsThemeString, RelativeSource={RelativeSource AncestorType=Page}}" 
                                      SelectedValuePath="Content">
                                <ComboBoxItem Content="Dark"/>
                                <ComboBoxItem Content="Light"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- Hotkeys Section -->
                <ui:CardExpander Icon="Keyboard24" Header="Global Hotkeys" Margin="0,0,0,12" IsExpanded="True">
                    <StackPanel>
                        <!-- Grid Hotkey -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Show Menu" FontWeight="Medium"/>
                                <TextBlock Text="Trigger the radial menu (Action Mode)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <ui:TextBox Grid.Column="1" Width="200"
                                     Text="{Binding DataContext.ShowGridHotkey, RelativeSource={RelativeSource AncestorType=Page}, Mode=OneWay}"
                                     PreviewKeyDown="Hotkey_PreviewKeyDown"
                                     GotFocus="Hotkey_GotFocus"
                                     LostFocus="Hotkey_LostFocus"
                                     Tag="ShowGrid"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PlaceholderText="Press keys..."/>
                        </Grid>
                        
                        <Separator Margin="0,12"/>

                        <!-- Switcher Hotkey -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Show Switcher" FontWeight="Medium"/>
                                <TextBlock Text="Trigger the window switcher (Launcher Mode)" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <ui:TextBox Grid.Column="1" Width="200"
                                     Text="{Binding DataContext.ShowSwitcherHotkey, RelativeSource={RelativeSource AncestorType=Page}, Mode=OneWay}"
                                     PreviewKeyDown="Hotkey_PreviewKeyDown"
                                     GotFocus="Hotkey_GotFocus"
                                     LostFocus="Hotkey_LostFocus"
                                     Tag="ShowSwitcher"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PlaceholderText="Press keys..."/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
