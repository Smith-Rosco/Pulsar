<Page x:Class="Pulsar.Views.Pages.SettingsExternalPluginsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      d:DataContext="{d:DesignInstance Type=vm:ExternalPluginManagerViewModel}"
      Title="SettingsExternalPluginsPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- External Plugin Card Style -->
            <Style x:Key="ExternalPluginCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="External Plugins"
                                     Description="Install and manage plugins from local ZIP files">
            <controls:SettingsPageHeader.ActionsContent>
                <ui:Button Content="Install from File"
                           Command="{Binding InstallFromFileCommand}"
                           Icon="{ui:SymbolIcon FolderOpen24}"
                           Style="{StaticResource PulsarPrimaryButtonStyle}"
                           ToolTip="Install a plugin from a local ZIP file"/>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,16,16,0">
            <StackPanel>
                <!-- Loading Indicator -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,48,0,0">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                    <TextBlock Text="Loading external plugins..."
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Installed External Plugins List -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                    <!-- Section Header -->
                    <TextBlock Text="{Binding InstalledPlugins.Count, StringFormat='Installed External Plugins ({0})'}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <!-- Plugin Cards -->
                    <ItemsControl ItemsSource="{Binding InstalledPlugins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ExternalPluginCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Plugin Icon -->
                                        <controls:JellyOrb Grid.Column="0"
                                                           IconKey="{Binding Icon}"
                                                           Size="48"
                                                           Width="48" Height="48"
                                                           IsTransparent="True"
                                                           ShowActiveGlow="False"
                                                           Margin="0,0,16,0"
                                                           VerticalAlignment="Top"/>

                                        <!-- Plugin Info -->
                                        <StackPanel Grid.Column="1">
                                            <!-- Title and Version -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                
                                                <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>

                                                <!-- Installed Badge -->
                                                <Border Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0">
                                                    <TextBlock Text="Installed"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Author -->
                                            <TextBlock Text="{Binding Author, StringFormat='by {0}'}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,0,8"/>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>

                                            <!-- Installation Path -->
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Folder24" FontSize="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding LocalPath}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <!-- Uninstall Button -->
                                            <ui:Button Content="Uninstall"
                                                       Command="{Binding DataContext.UninstallPluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon Delete24}"
                                                       Style="{StaticResource PulsarDangerButtonStyle}"
                                                       MinWidth="100"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="48"
                            Visibility="{Binding InstalledPlugins.Count, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Apps24"
                                           FontSize="64"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                            <TextBlock Text="No external plugins installed"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Click 'Install from File' to add plugins from ZIP packages"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="400"
                                       Margin="0,0,0,16"/>
                            <ui:Button Content="Install from File"
                                       Command="{Binding InstallFromFileCommand}"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Style="{StaticResource PulsarPrimaryButtonStyle}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Info Note -->
                    <Border Background="{DynamicResource ControlFillColorDisabledBrush}"
                            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,24,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Info24" 
                                               FontSize="16" 
                                               Foreground="{DynamicResource SystemAccentColorBrush}"
                                               Margin="0,0,8,0"/>
                                <TextBlock Text="About External Plugins" 
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       LineHeight="18">
                                <Run Text="• External plugins are loaded from ZIP files and installed to your local AppData folder"/>
                                <LineBreak/>
                                <Run Text="• Built-in plugins (PKI, WinSwitcher, etc.) are managed in the "/>
                                <Run Text="'Plugins'" FontWeight="SemiBold"/>
                                <Run Text=" tab"/>
                                <LineBreak/>
                                <Run Text="• After installation, restart Pulsar to load the new plugin"/>
                                <LineBreak/>
                                <Run Text="• Uninstalling a plugin requires a restart to complete removal"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Plugin Count -->
                <TextBlock Grid.Column="1"
                           Text="{Binding InstalledPlugins.Count, StringFormat='{}{0} external plugins installed'}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
