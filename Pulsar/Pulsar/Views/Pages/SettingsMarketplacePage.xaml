<Page x:Class="Pulsar.Views.Pages.SettingsMarketplacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      d:DataContext="{d:DesignInstance Type=vm:PluginMarketViewModel}"
      Title="SettingsMarketplacePage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Plugin Card Style -->
            <Style x:Key="MarketplacePluginCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.2"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Tag Chip Style -->
            <Style x:Key="TagChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Statistics Badge Style -->
            <Style x:Key="StatsBadgeStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="Plugin Marketplace"
                                     Description="Discover and install plugins to extend Pulsar's functionality">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal">
                    <!-- Refresh Button -->
                    <ui:Button Content="Refresh"
                               Command="{Binding RefreshPluginsCommand}"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Margin="0,0,8,0"/>
                    
                    <!-- Show Installed Only Toggle -->
                    <ui:ToggleSwitch Content="Installed Only"
                                     IsChecked="{Binding ShowInstalledOnly, Mode=TwoWay}"
                                     Margin="0,0,8,0"/>
                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Search and Filter Bar -->
        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <ui:TextBox Grid.Column="0"
                        PlaceholderText="Search plugins by name, author, or tags..."
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        ClearButtonEnabled="True"
                        Margin="0,0,12,0"/>

            <!-- Filter Dropdown -->
            <ui:Button Grid.Column="1"
                       Content="Clear Filters"
                       Command="{Binding ClearFilterCommand}"
                       Icon="{ui:SymbolIcon DismissCircle24}"
                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                       Visibility="{Binding SelectedTag, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Tags Filter -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Tags Header -->
                        <TextBlock Text="Categories"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <!-- All Plugins -->
                        <ui:Button Content="All Plugins"
                                   Command="{Binding FilterByTagCommand}"
                                   CommandParameter="{x:Null}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left"
                                   Margin="0,0,0,4"/>

                        <!-- Tag List -->
                        <ItemsControl ItemsSource="{Binding AvailableTags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:Button Content="{Binding}"
                                               Command="{Binding DataContext.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Left"
                                               Margin="0,0,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Statistics Section -->
                        <Separator Margin="0,16,0,12"/>
                        
                        <TextBlock Text="Statistics"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <StackPanel Visibility="{Binding Statistics, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Apps24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Statistics.TotalPackages, StringFormat='Total: {0}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Statistics.InstalledCount, StringFormat='Installed: {0}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Statistics.TotalDownloads, StringFormat='Downloads: {0:N0}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Content: Plugin List -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Loading Indicator -->
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,48,0,0">
                        <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                        <TextBlock Text="Loading plugins..."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Plugin Cards -->
                    <ItemsControl ItemsSource="{Binding AvailablePlugins}"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MarketplacePluginCardStyle}"
                                        MouseLeftButtonUp="PluginCard_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Plugin Icon -->
                                        <controls:JellyOrb Grid.Column="0"
                                                           IconKey="{Binding Icon}"
                                                           Size="48"
                                                           Width="48" Height="48"
                                                           IsTransparent="True"
                                                           ShowActiveGlow="False"
                                                           Margin="0,0,16,0"
                                                           VerticalAlignment="Top"/>

                                        <!-- Plugin Info -->
                                        <StackPanel Grid.Column="1">
                                            <!-- Title and Version -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                
                                                <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>

                                                <!-- Installed Badge -->
                                                <Border Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Installed"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>

                                                <!-- Update Available Badge -->
                                                <Border Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Update Available"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Author -->
                                            <TextBlock Text="{Binding Author, StringFormat='by {0}'}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,0,8"/>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,12"/>

                                            <!-- Tags -->
                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource TagChipStyle}">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Statistics Row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <!-- Rating -->
                                                <Border Style="{StaticResource StatsBadgeStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⭐" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Downloads -->
                                                <Border Style="{StaticResource StatsBadgeStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding DownloadCount, StringFormat='{}{0:N0}'}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Last Updated -->
                                                <Border Style="{StaticResource StatsBadgeStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Clock24" FontSize="12" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding LastUpdated, StringFormat='Updated {0:MMM dd, yyyy}'}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <!-- Install Button -->
                                            <ui:Button Content="Install"
                                                       Command="{Binding DataContext.InstallPluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                                       Style="{StaticResource PulsarPrimaryButtonStyle}"
                                                       Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVisConverter}}"
                                                       MinWidth="100"
                                                       Margin="0,0,0,4"/>

                                            <!-- Update Button -->
                                            <ui:Button Content="Update"
                                                       Command="{Binding DataContext.UpdatePluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                                       Style="{StaticResource PulsarPrimaryButtonStyle}"
                                                       Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                                                       MinWidth="100"
                                                       Margin="0,0,0,4"/>

                                            <!-- Uninstall Button -->
                                            <ui:Button Content="Uninstall"
                                                       Command="{Binding DataContext.UninstallPluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon Delete24}"
                                                       Style="{StaticResource PulsarDangerButtonStyle}"
                                                       Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                                       MinWidth="100"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,48,0,0"
                                Visibility="{Binding AvailablePlugins.Count, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="Apps24"
                                       FontSize="64"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"/>
                        <TextBlock Text="No plugins found"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Try adjusting your search or filters"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <ui:Button Content="Clear All Filters"
                                   Command="{Binding ClearFilterCommand}"
                                   Icon="{ui:SymbolIcon DismissCircle24}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Plugin Count -->
                <TextBlock Grid.Column="1"
                           Text="{Binding AvailablePlugins.Count, StringFormat='Showing {0} plugins'}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
