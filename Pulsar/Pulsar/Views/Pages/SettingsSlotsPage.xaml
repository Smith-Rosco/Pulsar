<Page x:Class="Pulsar.Views.Pages.SettingsSlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:models="clr-namespace:Pulsar.Models"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      xmlns:tutorial="clr-namespace:Pulsar.Helpers.Tutorial"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Slots Manager"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis"/>
            <converters:IsImagePathConverter x:Key="IsImagePath"/>
            <converters:StringPathToImageSourceConverter x:Key="PathToImage"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>

            <!-- SlotParameterFieldTemplate and SystemCommandFieldsTemplate removed: Quick Edit layer eliminated -->

            <!-- Custom Drag Adorner Template for Slot Cards -->
            <DataTemplate x:Key="SlotCardDragAdornerTemplate">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="12"
                        Opacity="0.9"
                        MinWidth="300">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" 
                                          Opacity="0.3" 
                                          BlurRadius="20" 
                                          ShadowDepth="4"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:SlotOrb Grid.Column="0"
                                           IconKey="{Binding IconKey}"
                                           Size="32"
                                           Width="32" Height="32"
                                           IsTransparent="True"
                                           ShowActiveGlow="False"
                                           Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Label}" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding Slot, StringFormat='Position {0}'}" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header: Title + Context Switcher + Profile Actions all in one row -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="Slots"
                                     Description="Configure actions for each context">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Context Switcher -->
                    <ui:SymbolIcon Symbol="Globe24"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableContexts}"
                              SelectedItem="{Binding CurrentContext, Mode=TwoWay}"
                              MinWidth="160"
                              MaxWidth="240"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:SlotOrb Grid.Column="0"
                                                       IconKey="{Binding Icon}"
                                                       Size="20"
                                                       Width="20" Height="20"
                                                       IsTransparent="True"
                                                       ShowActiveGlow="False"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SlotCount, StringFormat='{}{0} slots'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="18"
                               Fill="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>

                    <!-- Edit Profile -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Edit20}"
                               Command="{Binding EditProfileCommand}"
                               Visibility="{Binding CanEditProfile, Converter={StaticResource BoolToVis}}"
                               ToolTip="Edit Profile"
                               Margin="0,0,6,0"/>

                    <!-- Add Profile -->
                    <ui:Button Content="New Profile"
                               Icon="{ui:SymbolIcon Add24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               ToolTip="Add New Profile"
                               Command="{Binding AddProfileDialogCommand}"
                               Margin="0,0,6,0"/>

                    <!-- Delete Profile -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Command="{Binding DeleteProfileCommand}"
                               ToolTip="Delete Current Profile"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               Visibility="{Binding CanDeleteProfile, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Slots Area: ScrollViewer + FAB overlay -->
        <Grid Grid.Row="1">

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,64">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="DialPadOff24" FontSize="64" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="No Slots Configured" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Add a slot to start customizing this menu." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <ui:Button Content="Add First Slot"
                           Icon="{ui:SymbolIcon Add24}"
                           Style="{StaticResource PulsarPrimaryButtonStyle}"
                           Command="{Binding AddSlotDialogCommand}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Slot List -->
            <ScrollViewer x:Name="SlotsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,16,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource OverlayScrollViewerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding CurrentSlots}" 
                              AlternationCount="2"
                              Padding="0,0,0,60"
                              dd:DragDrop.IsDragSource="True"
                              dd:DragDrop.IsDropTarget="True"
                              dd:DragDrop.DropHandler="{Binding}"
                              dd:DragDrop.UseDefaultDragAdorner="False"
                              dd:DragDrop.DragAdornerTemplate="{StaticResource SlotCardDragAdornerTemplate}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PluginSlot}">
                            <!-- Drag Handle removed: whole card is draggable via Cursor=SizeAll -->
                            <controls:ExpandableCard
                                             x:Name="SlotCard"
                                             IconKey="{Binding IconKey}"
                                             OrbBackground="{Binding Color, Converter={StaticResource HexToBrush}}"
                                             Title="{Binding Label}"
                                             Subtitle="{Binding ActionLabel}"
                                             Cursor="SizeAll"
                                            IsToggleVisible="False"
                                            PrimaryActionVisibility="Collapsed"
                                            PageDataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                                <controls:ExpandableCard.CardContextMenu>
                                    <ContextMenu Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <ContextMenu.Resources>
                                            <ResourceDictionary>
                                                <ResourceDictionary.MergedDictionaries>
                                                    <ui:ControlsDictionary/>
                                                </ResourceDictionary.MergedDictionaries>
                                            </ResourceDictionary>
                                        </ContextMenu.Resources>
                                        <MenuItem Header="Edit Slot"
                                                  Click="ContextEdit_Click"
                                                  Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove Slot"
                                                  Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                  Click="ContextRemove_Click"
                                                  Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </controls:ExpandableCard.CardContextMenu>

                                <!-- Header Content: Position badge -->
                                <controls:ExpandableCard.HeaderContent>
                                     <Border Style="{StaticResource SlotChipBorderStyle}"
                                             Padding="5,1"
                                             VerticalAlignment="Center">
                                         <TextBlock Text="{Binding Slot, StringFormat='#{0}'}"
                                                    Style="{StaticResource SlotCaptionChipTextStyle}"
                                                    FontSize="10"/>
                                     </Border>
                                 </controls:ExpandableCard.HeaderContent>

                                <!-- Expanded Content -->
                                <controls:ExpandableCard.ExpandedContent>
                                    <StackPanel Margin="0,4,0,6"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                                Loaded="ExpandedPanel_Loaded">

                                        <!-- Type + Health + SummaryTokens info row -->
                                        <WrapPanel Margin="0,0,0,8">
                                            <!-- Type badge -->
                                             <Border Style="{StaticResource SlotChipBorderStyle}"
                                                     Visibility="{Binding TypeBadge, Converter={StaticResource StringEmptyToVis}, FallbackValue=Collapsed}"
                                                     ToolTip="Plugin type">
                                                  <StackPanel Orientation="Horizontal">
                                                      <TextBlock Text="Type · " Style="{StaticResource SlotCaptionChipTextStyle}"/>
                                                      <TextBlock Text="{Binding TypeBadge}"
                                                                 Style="{StaticResource SlotValueChipTextStyle}">
                                                          <TextBlock.Foreground>
                                                              <MultiBinding Converter="{StaticResource SlotBrushConverter}" ConverterParameter="Type">
                                                                  <Binding Path="TypeToneKey"/>
                                                                  <Binding RelativeSource="{RelativeSource Self}"/>
                                                              </MultiBinding>
                                                          </TextBlock.Foreground>
                                                      </TextBlock>
                                                  </StackPanel>
                                              </Border>
                                             <!-- Health badge -->
                                             <Border Style="{StaticResource SlotChipBorderStyle}"
                                                     ToolTip="Configuration health status">
                                                  <StackPanel Orientation="Horizontal">
                                                      <TextBlock Text="Health · " Style="{StaticResource SlotCaptionChipTextStyle}"/>
                                                      <TextBlock Text="{Binding HealthBadgeText}"
                                                                 Style="{StaticResource SlotValueChipTextStyle}">
                                                          <TextBlock.Foreground>
                                                              <MultiBinding Converter="{StaticResource SlotBrushConverter}" ConverterParameter="Health">
                                                                  <Binding Path="HealthToneKey"/>
                                                                  <Binding RelativeSource="{RelativeSource Self}"/>
                                                              </MultiBinding>
                                                          </TextBlock.Foreground>
                                                      </TextBlock>
                                                  </StackPanel>
                                              </Border>
                                            <!-- Summary tokens -->
                                            <ItemsControl ItemsSource="{Binding SummaryTokens}"
                                                          Visibility="{Binding HasSummaryTokens, Converter={StaticResource BoolToVis}}"
                                                          ToolTip="Configuration summary">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource SlotSummaryTokenBorderStyle}">
                                                            <TextBlock Text="{Binding}"
                                                                       Style="{StaticResource SlotCaptionChipTextStyle}"
                                                                       MaxWidth="120"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>

                                        <!-- Action buttons row -->
                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button Content="Edit Slot"
                                                       Icon="{ui:SymbolIcon Edit24}"
                                                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                                                       Margin="0,0,8,0"
                                                       Click="ExpandedEdit_Click"
                                                       Tag="{Binding}"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       Style="{StaticResource PulsarIconButtonStyle}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       ToolTip="Remove Slot"
                                                       Click="ExpandedRemove_Click"
                                                       Tag="{Binding}"/>
                                        </StackPanel>

                                    </StackPanel>
                                </controls:ExpandableCard.ExpandedContent>
                            </controls:ExpandableCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- FAB: Add Slot (floating, bottom-right) -->
            <ui:Button x:Name="AddSlotFab"
                       Icon="{ui:SymbolIcon Add24}"
                       Content="Add Slot"
                       Style="{StaticResource PulsarPrimaryButtonStyle}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,24,20"
                       Command="{Binding AddSlotDialogCommand}"
                       tutorial:TutorialMarker.Id="AddSlotButton"/>

        </Grid>
    </Grid>
</Page>
