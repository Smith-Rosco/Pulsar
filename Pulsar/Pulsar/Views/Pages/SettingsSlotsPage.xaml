<Page x:Class="Pulsar.Views.Pages.SettingsSlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:models="clr-namespace:Pulsar.Models"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      xmlns:tutorial="clr-namespace:Pulsar.Helpers.Tutorial"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Slots Manager"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis"/>
            <converters:IsImagePathConverter x:Key="IsImagePath"/>
            <converters:StringPathToImageSourceConverter x:Key="PathToImage"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>

            <DataTemplate x:Key="SlotParameterFieldTemplate" DataType="{x:Type models:SlotParameterEditorField}">
                <StackPanel Margin="0,0,0,8">
                    <!-- Single unified row: label | textbox | picker | info | badge -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Label}"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <ui:TextBox Grid.Column="1"
                                    Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{Binding Placeholder}"/>

                        <ui:Button Grid.Column="2"
                                   Margin="8,0,0,0"
                                   Content="{Binding PickerButtonLabel}"
                                   Click="SlotParameterPicker_Click"
                                   Tag="{Binding}"
                                   Visibility="{Binding HasPicker, Converter={StaticResource BoolToVis}}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"/>

                        <ui:Button Grid.Column="3"
                                   Width="28"
                                   Height="28"
                                   Margin="8,0,0,0"
                                   Icon="{ui:SymbolIcon Info24}"
                                   Style="{StaticResource PulsarIconButtonStyle}"
                                   ToolTip="{Binding HelpTooltipText}"
                                   Visibility="{Binding HasHelpContent, Converter={StaticResource BoolToVis}}"
                                   Focusable="True"/>

                        <Border Grid.Column="4"
                                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                CornerRadius="4"
                                Padding="6,1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Required" FontSize="10" Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding ValidationHint}"
                               Margin="104,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasValidationHint, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Text="{Binding ValidationMessage}"
                               Margin="104,2,0,0"
                               Foreground="{DynamicResource SystemFillColorCautionBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasValidationMessage, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </DataTemplate>

        <!-- 6. System Command -->
        <DataTemplate x:Key="SystemCommandFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,12,0"/>
                    
                    <ComboBox Grid.Column="1" SelectedValue="{Binding Action}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Open Settings" Tag="pulsar.system.open_settings"/>
                        <ComboBoxItem Content="Quick Add Profile &amp; Settings" Tag="pulsar.system.quick_add_profile"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Slot Item Context Menu (three-dot button) -->
        <ContextMenu x:Key="SlotItemContextMenu">
            <ContextMenu.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ui:ControlsDictionary />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ContextMenu.Resources>
            <MenuItem Header="Remove Slot"
                      Icon="{ui:SymbolIcon Delete24}"
                      Click="SlotContextMenu_RemoveSlot_Click"/>
        </ContextMenu>

        <!-- Context Menu Style -->
        <ContextMenu x:Key="AddSlotContextMenu"
                     ItemsSource="{Binding AvailablePluginTypes}">
            <ContextMenu.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ui:ControlsDictionary />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ContextMenu.Resources>
            <ContextMenu.ItemContainerStyle>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                    <Setter Property="Header" Value="{Binding DisplayName}"/>
                    <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.AddSlotOfTypeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Setter Property="CommandParameter" Value="{Binding PluginId}"/>
                    <Setter Property="ToolTip" Value="{Binding Description}"/>
                </Style>
            </ContextMenu.ItemContainerStyle>
        </ContextMenu>

        <!-- Custom Drag Adorner Template for Slot Cards -->
        <DataTemplate x:Key="SlotCardDragAdornerTemplate">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12"
                    Opacity="0.9"
                    MinWidth="300">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                    Opacity="0.3" 
                                    BlurRadius="20" 
                                    ShadowDepth="4"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                </Border.RenderTransform>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <controls:JellyOrb Grid.Column="0"
                                     IconKey="{Binding IconKey}"
                                     Size="32"
                                     Width="32" Height="32"
                                     IsTransparent="True"
                                     ShowActiveGlow="False"
                                     Margin="0,0,12,0"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}" 
                                 FontSize="14" 
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding Slot, StringFormat='Position {0}'}" 
                                 FontSize="12"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="{Binding CurrentContext.DisplayName, FallbackValue='Slots'}"
                                     Description="Configure actions for this context">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal">
                    <!-- Context Switcher -->
                    <ComboBox ItemsSource="{Binding AvailableContexts}" 
                              SelectedItem="{Binding CurrentContext}"
                              Width="220"
                              ToolTip="Switch Menu Context"
                              Margin="0,0,8,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <controls:JellyOrb Grid.Column="0"
                                                       IconKey="{Binding Icon}"
                                                       Size="20"
                                                       Width="20" Height="20"
                                                       IsTransparent="True"
                                                       ShowActiveGlow="False"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DisplayName}" 
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                               
                                    <Border Grid.Column="2" 
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                            CornerRadius="4" 
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding SlotCount}" 
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                            <TextBlock Text=" slots" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Edit Profile Button -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Edit20}"
                               Command="{Binding EditProfileCommand}"
                               Visibility="{Binding CanEditProfile, Converter={StaticResource BoolToVis}}"
                               ToolTip="Edit Profile Alias &amp; Icon"
                               Margin="0,0,8,0"/>

                    <!-- Add Profile Button -->
                    <ui:Button Icon="{ui:SymbolIcon Add24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               ToolTip="Add New Profile"
                               Command="{Binding AddProfileDialogCommand}"
                               Margin="0,0,8,0"/>

                    <!-- Delete Button -->
                    <ui:Button Style="{StaticResource PulsarDangerButtonStyle}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Command="{Binding DeleteProfileCommand}"
                               ToolTip="Delete Current Profile"
                               Visibility="{Binding CanDeleteProfile, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Slots List -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Empty State -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,32">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="DialPadOff24" FontSize="64" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="No Slots Configured" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Add a slot below to start customizing this menu." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource OverlayScrollViewerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding CurrentSlots}" 
                              AlternationCount="2"
                              dd:DragDrop.IsDragSource="True"
                              dd:DragDrop.IsDropTarget="True"
                              dd:DragDrop.DropHandler="{Binding}"
                              dd:DragDrop.UseDefaultDragAdorner="False"
                              dd:DragDrop.DragAdornerTemplate="{StaticResource SlotCardDragAdornerTemplate}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PluginSlot}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Drag Handle (outside card for better UX) -->
                                <Border Grid.Column="0"
                                        Background="Transparent"
                                        Padding="4"
                                        Margin="0,0,8,0"
                                        CornerRadius="4"
                                        Cursor="SizeAll"
                                        ToolTip="Drag to reorder">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" 
                                                            Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <ui:SymbolIcon Symbol="Navigation24" 
                                                   FontSize="20"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                </Border>
                                
                                 <controls:ExpandableCard Grid.Column="1"
                                                          x:Name="SlotCard"
                                                          IconKey="{Binding IconKey}"
                                                          Title="{Binding Label}"
                                                          Subtitle="{Binding ActionLabel}"
                                                          IsToggleVisible="False"
                                                          PageDataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                                    
                                     <!-- Header Content: Position + Status + Three-dot menu -->
                                      <controls:ExpandableCard.HeaderContent>
                                           <WrapPanel>
                                                     <TextBlock Text="{Binding Slot, StringFormat='Position {0}'}"
                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                FontSize="12"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"/>
                                                   <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                           CornerRadius="999"
                                                           Padding="8,2"
                                                           Margin="0,0,8,0"
                                                           Visibility="{Binding TypeBadge, Converter={StaticResource StringEmptyToVis}, FallbackValue=Collapsed}">
                                                       <TextBlock Text="{Binding TypeBadge}" FontSize="10" Foreground="{Binding TypeColor}"/>
                                                   </Border>
                                                     <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                             CornerRadius="999"
                                                             Padding="8,2"
                                                             Margin="0,0,8,0">
                                                         <TextBlock Text="{Binding HealthBadgeText}" FontSize="10" Foreground="{Binding HealthBadgeColor}"/>
                                                     </Border>
                                                     <!-- SummaryTokens chips (max 3) -->
                                                     <ItemsControl ItemsSource="{Binding SummaryTokens}"
                                                                   Visibility="{Binding HasSummaryTokens, Converter={StaticResource BoolToVis}}">
                                                         <ItemsControl.ItemsPanel>
                                                             <ItemsPanelTemplate>
                                                                 <WrapPanel Orientation="Horizontal"/>
                                                             </ItemsPanelTemplate>
                                                         </ItemsControl.ItemsPanel>
                                                         <ItemsControl.ItemTemplate>
                                                             <DataTemplate>
                                                                 <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                         CornerRadius="999"
                                                                         Padding="6,2"
                                                                         Margin="0,0,4,0"
                                                                         BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                         BorderThickness="1">
                                                                     <TextBlock Text="{Binding}" FontSize="10"
                                                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                MaxWidth="80"
                                                                                TextTrimming="CharacterEllipsis"/>
                                                                 </Border>
                                                             </DataTemplate>
                                                         </ItemsControl.ItemTemplate>
                                                     </ItemsControl>
                                                     <!-- Three-dot context menu button -->
                                                     <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                                                                Icon="{ui:SymbolIcon MoreHorizontal24}"
                                                                ToolTip="More options"
                                                                Padding="4"
                                                                Click="SlotMoreButton_Click"
                                                                Tag="{Binding}"/>
                                           </WrapPanel>
                                        </controls:ExpandableCard.HeaderContent>
                                      
                                     <!-- Expanded Content: Quick Edit -->
                                      <controls:ExpandableCard.ExpandedContent>
                                          <StackPanel Loaded="StackPanel_Loaded">
                                              <!-- ValidationSummary: severity-aware -->
                                              <Border CornerRadius="8"
                                                       Padding="10,8"
                                                       Margin="0,0,0,12"
                                                       Visibility="{Binding HasValidationSummary, Converter={StaticResource BoolToVis}}">
                                                  <Border.Style>
                                                      <Style TargetType="Border">
                                                          <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}"/>
                                                          <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}"/>
                                                          <Setter Property="BorderThickness" Value="1"/>
                                                          <Style.Triggers>
                                                              <DataTrigger Binding="{Binding ValidationSeverity}" Value="Error">
                                                                  <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                                                                  <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                              </DataTrigger>
                                                          </Style.Triggers>
                                                      </Style>
                                                  </Border.Style>
                                                  <Grid>
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="Auto"/>
                                                          <ColumnDefinition Width="*"/>
                                                      </Grid.ColumnDefinitions>
                                                      <!-- Warning icon (default) -->
                                                      <ui:SymbolIcon Symbol="Warning24"
                                                                     FontSize="14"
                                                                     Margin="0,0,8,0"
                                                                     VerticalAlignment="Top">
                                                          <ui:SymbolIcon.Style>
                                                              <Style TargetType="ui:SymbolIcon">
                                                                  <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}"/>
                                                                  <Setter Property="Visibility" Value="Visible"/>
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding ValidationSeverity}" Value="Error">
                                                                          <Setter Property="Visibility" Value="Collapsed"/>
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </ui:SymbolIcon.Style>
                                                      </ui:SymbolIcon>
                                                      <!-- Error icon -->
                                                      <ui:SymbolIcon Symbol="ErrorCircle24"
                                                                     FontSize="14"
                                                                     Margin="0,0,8,0"
                                                                     VerticalAlignment="Top">
                                                          <ui:SymbolIcon.Style>
                                                              <Style TargetType="ui:SymbolIcon">
                                                                  <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                                  <Setter Property="Visibility" Value="Collapsed"/>
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding ValidationSeverity}" Value="Error">
                                                                          <Setter Property="Visibility" Value="Visible"/>
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </ui:SymbolIcon.Style>
                                                      </ui:SymbolIcon>
                                                      <TextBlock Grid.Column="1"
                                                                 Text="{Binding ValidationSummary}"
                                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                 TextWrapping="Wrap"/>
                                                  </Grid>
                                              </Border>

                                             <Grid Margin="0,0,0,8">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="100"/>
                                                     <ColumnDefinition Width="*"/>
                                                 </Grid.ColumnDefinitions>

                                                 <TextBlock Text="Label"
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                                 <ui:TextBox Grid.Column="1"
                                                             Text="{Binding Label}"
                                                             PlaceholderText="Display label"/>
                                             </Grid>

                                             <Grid Margin="0,0,0,8"
                                                   Visibility="{Binding HasActionChoices, Converter={StaticResource BoolToVis}}">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="100"/>
                                                     <ColumnDefinition Width="*"/>
                                                 </Grid.ColumnDefinitions>

                                                 <TextBlock Text="Action"
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                 <ComboBox Grid.Column="1"
                                                           ItemsSource="{Binding AvailableActions}"
                                                           SelectedValuePath="Value"
                                                           DisplayMemberPath="Label"
                                                           SelectedValue="{Binding Action}"
                                                           SelectionChanged="ActionComboBox_SelectionChanged"/>
                                             </Grid>

                                              <ItemsControl ItemsSource="{Binding QuickEditParameters}"
                                                            ItemTemplate="{StaticResource SlotParameterFieldTemplate}"
                                                            Visibility="{Binding HasQuickEditParameters, Converter={StaticResource BoolToVis}}"/>

                                              <!-- Hint when no QuickEditParameters -->
                                              <TextBlock Text="Open Edit Details for full configuration"
                                                         Margin="0,4,0,8"
                                                         FontSize="12"
                                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                         FontStyle="Italic"
                                                         HorizontalAlignment="Center">
                                                  <TextBlock.Style>
                                                      <Style TargetType="TextBlock">
                                                          <Setter Property="Visibility" Value="Collapsed"/>
                                                          <Style.Triggers>
                                                              <DataTrigger Binding="{Binding HasQuickEditParameters}" Value="False">
                                                                  <Setter Property="Visibility" Value="Visible"/>
                                                              </DataTrigger>
                                                          </Style.Triggers>
                                                      </Style>
                                                  </TextBlock.Style>
                                              </TextBlock>

                                              <!-- Edit Details: single full-width action button -->
                                              <ui:Button Content="Edit Details"
                                                         Margin="0,10,0,0"
                                                         Icon="{ui:SymbolIcon Settings24}"
                                                         Style="{StaticResource PulsarSecondaryButtonStyle}"
                                                         Command="{Binding Tag.OpenSlotConfigurationCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                                         CommandParameter="{Binding}"
                                                         HorizontalAlignment="Stretch"/>
                                          </StackPanel>
                                      </controls:ExpandableCard.ExpandedContent>
                                 </controls:ExpandableCard>
                             </Grid>
                         </DataTemplate>
                     </ItemsControl.ItemTemplate>
                 </ItemsControl>
             </ScrollViewer>

            <!-- Footer: Add Slot Button -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
            <ui:Button x:Name="AddSlotButton"
                       Content="Add Slot" 
                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                       Icon="{ui:SymbolIcon Add24}"
                       HorizontalAlignment="Stretch"
                       Height="40"
                       Click="AddSlotButton_Click"
                       ContextMenu="{StaticResource AddSlotContextMenu}"
                       tutorial:TutorialMarker.Id="AddSlotButton"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
