<Page x:Class="Pulsar.Views.Pages.SettingsSlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:models="clr-namespace:Pulsar.Models"
      xmlns:selectors="clr-namespace:Pulsar.Views.Selectors"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Slots Manager"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis"/>
            <converters:IsImagePathConverter x:Key="IsImagePath"/>
            <converters:StringPathToImageSourceConverter x:Key="PathToImage"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>

            <!-- Templates for different Plugin Types -->
        
        <!-- 1. WinSwitcher / Launcher -->
        <DataTemplate x:Key="LauncherFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding [app]}" 
                                Icon="{ui:SymbolIcon Search24}"
                                PlaceholderText="Process Name (e.g. chrome)"
                                ToolTip="This name is used for switching to the window."/>
                    
                                <ui:Button Grid.Column="1" Margin="8,0,0,0"
                                           Icon="{ui:SymbolIcon TargetEdit20}"
                                           Command="{Binding Tag.PickProcessCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                           CommandParameter="{Binding}"
                                           ToolTip="Pick Executable from Running App"
                                           Style="{StaticResource PulsarIconButtonStyle}"/>
                </Grid>

                <ui:TextBox Text="{Binding [arguments]}" 
                            Icon="{ui:SymbolIcon Code24}"
                            PlaceholderText="Arguments (Optional)"
                            Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

        <!-- 2. Command Runner -->
        <DataTemplate x:Key="CommandFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding [path]}" 
                                Icon="{ui:SymbolIcon AppGeneric24}"
                                PlaceholderText="Executable Path"/>
                    
                    <ui:Button Grid.Column="1" Margin="8,0,0,0"
                               Icon="{ui:SymbolIcon TargetEdit20}"
                               Command="{Binding Tag.PickProcessCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                               CommandParameter="{Binding}"
                               ToolTip="Pick Executable from Running App"
                               Style="{StaticResource PulsarIconButtonStyle}"/>
                </Grid>

                <ui:TextBox Text="{Binding [arguments]}" 
                            Icon="{ui:SymbolIcon Code24}"
                            PlaceholderText="Arguments (Optional)"
                            Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

        <!-- 3. Secret (PKI) -->
        <DataTemplate x:Key="SecretFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ui:TextBox Text="••••••••••••••••" 
                                Icon="{ui:SymbolIcon LockClosed24}"
                                IsEnabled="False"
                                ToolTip="Encrypted Credential"/>

                                <ui:Button Grid.Column="1" Margin="8,0,0,0"
                                           Icon="{ui:SymbolIcon Edit24}"
                                           Content="Edit Secret"
                                           Command="{Binding Tag.EditSecretCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                           CommandParameter="{Binding}"
                                           Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- 4. Bookmarklet -->
        <DataTemplate x:Key="BookmarkletFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding [scriptPath]}" 
                                Icon="{ui:SymbolIcon DocumentJavascript24}"
                                PlaceholderText="Script Path (.js)"
                                ToolTip="Path to .js file"/>

                                <ui:Button Grid.Column="1" Margin="8,0,0,0"
                                           Icon="{ui:SymbolIcon FolderOpen24}"
                                           Command="{Binding Tag.PickScriptFileCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                           CommandParameter="{Binding}"
                                           ToolTip="Browse Script File"
                                           Style="{StaticResource PulsarIconButtonStyle}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- 5. VBA Runner -->
        <DataTemplate x:Key="VbaRunnerFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Text="{Binding [scriptPath]}" 
                                Icon="{ui:SymbolIcon DocumentData24}"
                                PlaceholderText="VBA Script Path (.txt/.vbs)"
                                ToolTip="Path to .txt/.vbs file"/>

                                <ui:Button Grid.Column="1" Margin="8,0,0,0"
                                           Icon="{ui:SymbolIcon FolderOpen24}"
                                           Command="{Binding Tag.PickVbaScriptFileCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                           CommandParameter="{Binding}"
                                           ToolTip="Browse VBA Script"
                                           Style="{StaticResource PulsarIconButtonStyle}"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- 6. System Command -->
        <DataTemplate x:Key="SystemCommandFieldsTemplate">
            <StackPanel Loaded="DataTemplateStackPanel_Loaded">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,12,0"/>
                    
                    <ComboBox Grid.Column="1" SelectedValue="{Binding Action}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Open Settings" Tag="pulsar.system.open_settings"/>
                        <ComboBoxItem Content="Quick Add Profile &amp; Settings" Tag="pulsar.system.quick_add_profile"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <selectors:SlotItemFieldSelector x:Key="SlotItemFieldSelector"
                                         LauncherFieldsTemplate="{StaticResource LauncherFieldsTemplate}"
                                         CommandFieldsTemplate="{StaticResource CommandFieldsTemplate}"
                                         BookmarkletFieldsTemplate="{StaticResource BookmarkletFieldsTemplate}"
                                         VbaRunnerFieldsTemplate="{StaticResource VbaRunnerFieldsTemplate}"
                                         SecretFieldsTemplate="{StaticResource SecretFieldsTemplate}"
                                         SystemCommandFieldsTemplate="{StaticResource SystemCommandFieldsTemplate}"/>

        <!-- Context Menu Style -->
        <ContextMenu x:Key="AddSlotContextMenu"
                     ItemsSource="{Binding AvailablePluginTypes}">
            <ContextMenu.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ui:ControlsDictionary />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ContextMenu.Resources>
            <ContextMenu.ItemContainerStyle>
                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                    <Setter Property="Header" Value="{Binding DisplayName}"/>
                    <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.AddSlotOfTypeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Setter Property="CommandParameter" Value="{Binding PluginId}"/>
                    <Setter Property="ToolTip" Value="{Binding Description}"/>
                </Style>
            </ContextMenu.ItemContainerStyle>
        </ContextMenu>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="{Binding CurrentContext.DisplayName, FallbackValue='Slots'}"
                                     Description="Configure actions for this context">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal">
                    <!-- Context Switcher -->
                    <ComboBox ItemsSource="{Binding AvailableContexts}" 
                              SelectedItem="{Binding CurrentContext}"
                              Width="220"
                              ToolTip="Switch Menu Context"
                              Margin="0,0,8,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <controls:JellyOrb Grid.Column="0"
                                                       IconKey="{Binding Icon}"
                                                       Size="20"
                                                       Width="20" Height="20"
                                                       IsTransparent="True"
                                                       ShowActiveGlow="False"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DisplayName}" 
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                               
                                    <Border Grid.Column="2" 
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                            CornerRadius="4" 
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding SlotCount}" 
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                            <TextBlock Text=" slots" 
                                                       FontSize="12" 
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Edit Profile Button -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Edit20}"
                               Command="{Binding EditProfileCommand}"
                               Visibility="{Binding CanEditProfile, Converter={StaticResource BoolToVis}}"
                               ToolTip="Edit Profile Alias &amp; Icon"
                               Margin="0,0,8,0"/>

                    <!-- Add Profile Button -->
                    <ui:Button Icon="{ui:SymbolIcon Add24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               ToolTip="Add New Profile"
                               Command="{Binding AddProfileDialogCommand}"
                               Margin="0,0,8,0"/>

                    <!-- Delete Button -->
                    <ui:Button Style="{StaticResource PulsarDangerButtonStyle}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Command="{Binding DeleteProfileCommand}"
                               ToolTip="Delete Current Profile"
                               Visibility="{Binding CanDeleteProfile, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Slots List -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Empty State -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,32">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="DialPadOff24" FontSize="64" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="No Slots Configured" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Add a slot below to start customizing this menu." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource OverlayScrollViewerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding CurrentSlots}" 
                              AlternationCount="2"
                              dd:DragDrop.IsDragSource="True"
                              dd:DragDrop.IsDropTarget="True"
                              dd:DragDrop.DropHandler="{Binding}"
                              dd:DragDrop.UseDefaultDragAdorner="True"
                              dd:DragDrop.DefaultDragAdornerOpacity="0.5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PluginSlot}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Drag Handle (outside card for better UX) -->
                                <ui:SymbolIcon Grid.Column="0" 
                                               Symbol="Navigation24" 
                                               FontSize="20"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Cursor="SizeAll"
                                               ToolTip="Drag to reorder"/>
                                
                                <controls:ExpandableCard Grid.Column="1"
                                                         x:Name="SlotCard"
                                                         IconKey="{Binding IconKey}"
                                                         Title="{Binding Label}"
                                                         IsToggleVisible="False"
                                                         PageDataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                                    
                                    <!-- Header Content: Position + Type Badge -->
                                    <controls:ExpandableCard.HeaderContent>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Slot, StringFormat='Position {0}'}" 
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                                       FontSize="12" Margin="0,0,8,0"/>
                                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                                    CornerRadius="4" Padding="4,1"
                                                    Visibility="{Binding TypeBadge, Converter={StaticResource StringEmptyToVis}, FallbackValue=Collapsed}">
                                                <TextBlock Text="{Binding TypeBadge}" FontSize="10" Foreground="{Binding TypeColor}"/>
                                            </Border>
                                        </StackPanel>
                                    </controls:ExpandableCard.HeaderContent>
                                    
                                    <!-- Expanded Content: Slot Configuration Form -->
                                    <controls:ExpandableCard.ExpandedContent>
                                        <StackPanel Loaded="StackPanel_Loaded">
                                            <ui:TextBox Text="{Binding Label}" PlaceholderText="Display Label" Margin="0,0,0,10"/>
                                            
                                            <!-- Dynamic Fields based on Type -->
                                            <ContentPresenter Content="{Binding}" ContentTemplateSelector="{StaticResource SlotItemFieldSelector}"/>

                                            <!-- Appearance Section (Shared) -->
                                            <TextBlock Text="Appearance" FontSize="12" FontWeight="SemiBold" Margin="0,12,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon Field -->
                                                <Grid Grid.Column="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Text="{Binding IconKey}" 
                                                                Icon="{ui:SymbolIcon Image24}"
                                                                PlaceholderText="Icon, Emoji, or Text"/>
                            <ui:Button Grid.Column="1" Margin="4,0,0,0"
                                       Icon="{ui:SymbolIcon FolderOpen16}"
                                       Style="{StaticResource PulsarIconButtonStyle}"
                                       Command="{Binding Tag.PickIconCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                       CommandParameter="{Binding}"
                                       ToolTip="Browse Icon File"/>
                                                </Grid>

                                                <!-- Color Field -->
                                                <Grid Grid.Column="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="4" Margin="0,0,8,0"
                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                                                            Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                                    </Border>

                                                    <ui:TextBox Grid.Column="1" 
                                                                Text="{Binding Color}" 
                                                                Icon="{ui:SymbolIcon Color24}"
                                                                PlaceholderText="#RRGGBB"/>

                            <ui:Button Grid.Column="2" Margin="4,0,0,0"
                                       Icon="{ui:SymbolIcon Drop24}"
                                       Style="{StaticResource PulsarIconButtonStyle}"
                                       Command="{Binding Tag.PickColorCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}" 
                                       CommandParameter="{Binding}"
                                       ToolTip="Pick Color from Palette"/>
                                                </Grid>
                                            </Grid>
                                            
                                            <!-- Action Buttons Row -->
                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                        <ui:Button Grid.Column="0"
                                   Content="Move Up"
                                   Icon="{ui:SymbolIcon ArrowUp24}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   Command="{Binding Tag.MoveSlotUpCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                   CommandParameter="{Binding}"
                                   HorizontalAlignment="Stretch"/>
                                                
                        <ui:Button Grid.Column="2"
                                   Content="Move Down"
                                   Icon="{ui:SymbolIcon ArrowDown24}"
                                   Style="{StaticResource PulsarSecondaryButtonStyle}"
                                   Command="{Binding Tag.MoveSlotDownCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                   CommandParameter="{Binding}"
                                   HorizontalAlignment="Stretch"/>
                                                
                        <ui:Button Grid.Column="4"
                                   Content="Remove"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Style="{StaticResource PulsarDangerButtonStyle}"
                                   Command="{Binding Tag.RemoveSlotCommand, RelativeSource={RelativeSource AncestorType=StackPanel}}"
                                   CommandParameter="{Binding}"
                                   HorizontalAlignment="Stretch"/>
                                            </Grid>
                                        </StackPanel>
                                    </controls:ExpandableCard.ExpandedContent>
                                </controls:ExpandableCard>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer: Add Slot Button -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
            <ui:Button Content="Add Slot" 
                       Style="{StaticResource PulsarSecondaryButtonStyle}"
                       Icon="{ui:SymbolIcon Add24}"
                       HorizontalAlignment="Stretch"
                       Height="40"
                       Click="AddSlotButton_Click"
                       ContextMenu="{StaticResource AddSlotContextMenu}"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
