<Page x:Class="Pulsar.Views.Pages.SettingsSlotsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:models="clr-namespace:Pulsar.Models"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      xmlns:tutorial="clr-namespace:Pulsar.Helpers.Tutorial"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:lex="clr-namespace:Pulsar.Core.Localization"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="{lex:Locale Settings.Slots.Title}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/SlotStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVis"/>
            <converters:IsImagePathConverter x:Key="IsImagePath"/>
            <converters:StringPathToImageSourceConverter x:Key="PathToImage"/>
            <converters:HexToBrushConverter x:Key="HexToBrush"/>
            <converters:SlotBrushConverter x:Key="SlotBrushConverter"/>

            <!-- SlotParameterFieldTemplate and SystemCommandFieldsTemplate removed: Quick Edit layer eliminated -->

            <!-- Custom Drag Adorner Template for Slot Cards -->
            <DataTemplate x:Key="SlotCardDragAdornerTemplate">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="12"
                        Opacity="0.9"
                        MinWidth="300">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" 
                                          Opacity="0.3" 
                                          BlurRadius="20" 
                                          ShadowDepth="4"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:SlotOrb Grid.Column="0"
                                           IconKey="{Binding IconKey}"
                                           Size="32"
                                           Width="32" Height="32"
                                           IsTransparent="True"
                                           ShowActiveGlow="False"
                                           Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Label}" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding Slot, StringFormat={lex:Locale Settings.Slots.PositionFormat}}" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header: Title + Context Switcher + Profile Actions all in one row -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="{lex:Locale Settings.Slots.Slots}"
                                     Description="{lex:Locale Settings.Slots.Description}">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Context Switcher -->
                    <ComboBox ItemsSource="{Binding AvailableContexts}"
                              SelectedItem="{Binding CurrentContext, Mode=TwoWay}"
                              MinWidth="160"
                              MaxWidth="240"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:SlotOrb Grid.Column="0"
                                                       IconKey="{Binding Icon}"
                                                       Size="20"
                                                       Width="20" Height="20"
                                                       IsTransparent="True"
                                                       ShowActiveGlow="False"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SlotCount, StringFormat={lex:Locale Settings.Slots.SlotCountFormat}}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Divider -->
                    <Rectangle Width="1" Height="18"
                               Fill="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>

                    <!-- Edit Profile -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Edit20}"
                               Command="{Binding EditProfileCommand}"
                               Visibility="{Binding CanEditProfile, Converter={StaticResource BoolToVis}}"
                               ToolTip="{lex:Locale Settings.Slots.EditProfile}"
                               Margin="0,0,6,0"/>

                    <!-- Add Profile -->
                    <ui:Button Content="{lex:Locale Settings.Slots.NewProfile}"
                               Icon="{ui:SymbolIcon Add24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               ToolTip="{lex:Locale Settings.Slots.NewProfileTooltip}"
                               Command="{Binding AddProfileDialogCommand}"
                               Margin="0,0,6,0"/>

                    <!-- Delete Profile -->
                    <ui:Button Style="{StaticResource PulsarIconButtonStyle}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Command="{Binding DeleteProfileCommand}"
                               ToolTip="{lex:Locale Settings.Slots.DeleteProfileTooltip}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               Visibility="{Binding CanDeleteProfile, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Slots Area: ScrollViewer + FAB overlay -->
        <Grid Grid.Row="1">

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,64">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="DialPadOff24" FontSize="64" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16"/>
                <TextBlock Text="{lex:Locale Settings.Slots.NoSlotsConfigured}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="{lex:Locale Settings.Slots.AddSlotHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <ui:Button Content="{lex:Locale Settings.Slots.AddFirstSlot}"
                           Icon="{ui:SymbolIcon Add24}"
                           Style="{StaticResource PulsarPrimaryButtonStyle}"
                           Command="{Binding AddSlotDialogCommand}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Slot List -->
            <ScrollViewer x:Name="SlotsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,16,0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource OverlayScrollViewerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSlots.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSlots}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding CurrentSlots}" 
                              AlternationCount="2"
                              Padding="0,0,0,60"
                              dd:DragDrop.IsDragSource="True"
                              dd:DragDrop.IsDropTarget="True"
                              dd:DragDrop.DropHandler="{Binding}"
                              dd:DragDrop.UseDefaultDragAdorner="False"
                              dd:DragDrop.DragAdornerTemplate="{StaticResource SlotCardDragAdornerTemplate}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PluginSlot}">
                            <Border x:Name="SlotCard"
                                    Margin="0,0,0,8"
                                    Padding="12,10"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Cursor="SizeAll">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Slot Orb -->
                                    <Border Grid.Column="0"
                                            Style="{StaticResource SlotOrbContainerStyle}"
                                            Margin="0,0,10,0"
                                            Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                        <controls:SlotOrb IconKey="{Binding IconKey}"
                                                           Size="28" Width="28" Height="28"
                                                           Margin="5"
                                                           IsTransparent="True"
                                                           ShowActiveGlow="False"/>
                                    </Border>

                                    <!-- Title + Subtitle + Position Badge -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <Border Style="{StaticResource SlotChipBorderStyle}"
                                                    Padding="5,1"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Slot, StringFormat='#{0}'}"
                                                           Style="{StaticResource SlotCaptionChipTextStyle}"
                                                           FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ActionLabel}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding ActionLabel, Converter={StaticResource StringEmptyToVis}}"/>
                                    </StackPanel>

                                    <!-- Edit Button -->
                                    <ui:Button Grid.Column="2"
                                               x:Name="EditButton"
                                               Icon="{ui:SymbolIcon Edit24}"
                                               Style="{StaticResource PulsarIconButtonStyle}"
                                               ToolTip="{lex:Locale Settings.Slots.EditSlot}"
                                               Click="SlotEdit_Click"
                                               Tag="{Binding}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               Visibility="Collapsed"/>

                                    <!-- Delete Button -->
                                    <ui:Button Grid.Column="3"
                                               x:Name="DeleteButton"
                                               Icon="{ui:SymbolIcon Delete24}"
                                               Style="{StaticResource PulsarIconButtonStyle}"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               ToolTip="{lex:Locale Settings.Slots.RemoveSlot}"
                                               Click="SlotRemove_Click"
                                               Tag="{Binding}"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <Trigger SourceName="SlotCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="EditButton" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- FAB: Add Slot (floating, bottom-right) -->
            <ui:Button x:Name="AddSlotFab"
                       Icon="{ui:SymbolIcon Add24}"
                       Content="{lex:Locale Settings.Slots.AddSlot}"
                       Style="{StaticResource PulsarPrimaryButtonStyle}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,24,20"
                       Command="{Binding AddSlotDialogCommand}"
                       tutorial:TutorialMarker.Id="AddSlotButton"/>

        </Grid>
    </Grid>
</Page>
