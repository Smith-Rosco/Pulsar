<Page x:Class="Pulsar.Views.Pages.SettingsPluginsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
      xmlns:ts="clr-namespace:Pulsar.Views.TemplateSelectors"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      xmlns:controls="clr-namespace:Pulsar.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="SettingsPluginsPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
            <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Plugin Context Menu -->
        <ContextMenu x:Key="PluginContextMenu">
            <ContextMenu.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ui:ControlsDictionary/>
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ContextMenu.Resources>
            <MenuItem Header="Configure" 
                      Command="{Binding ConfigureCommand}"
                      Visibility="{Binding HasSettings, Converter={StaticResource BoolToVis}}">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="Settings24"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="View Logs" 
                      Command="{Binding ViewLogsCommand}">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="DocumentText24"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Refresh Analytics" 
                      Command="{Binding RefreshAnalyticsCommand}">
                <MenuItem.Icon>
                    <ui:SymbolIcon Symbol="ArrowClockwise24"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="PluginsGroupExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ToggleButton Grid.Row="0"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0,4,0,8"
                                          HorizontalContentAlignment="Left">
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>

                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Row="1"
                                              ContentSource="Content"
                                              Margin="0,8,0,0"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" TargetName="contentPresenter"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Lightweight Group Header Style -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="PluginDashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Setting Templates -->
        <DataTemplate x:Key="BooleanSettingTemplate" DataType="{x:Type vm:BooleanSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding BoolValue, Mode=TwoWay}"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="StringSettingTemplate" DataType="{x:Type vm:StringSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:TextBox Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Width="220"
                            HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="SelectionSettingTemplate" DataType="{x:Type vm:SelectionSettingViewModel}">
             <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox ItemsSource="{Binding Options}" 
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          Width="220"
                          HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <ts:PluginSettingTemplateSelector x:Key="SettingSelector"
                                          BooleanTemplate="{StaticResource BooleanSettingTemplate}"
                                          StringTemplate="{StaticResource StringSettingTemplate}"
                                          SelectionTemplate="{StaticResource SelectionSettingTemplate}"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Unified Page Header -->
        <controls:SettingsPageHeader Grid.Row="0"
                                     Title="Plugins"
                                     Description="Manage plugin lifecycle, health, and configuration">
            <controls:SettingsPageHeader.ActionsContent>
                <StackPanel Orientation="Horizontal">
                    <!-- Search Box (only visible on Built-in tab) -->
                    <ui:TextBox PlaceholderText="Search plugins..."
                                Icon="{ui:SymbolIcon Search24}"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                ClearButtonEnabled="True"
                                Width="240"
                                Margin="0,0,8,0"/>
                    
                    <!-- Quick Navigation Buttons -->
                    <ui:Button Content="Core"
                               Icon="{ui:SymbolIcon Shield24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Click="JumpToCoreButton_Click"
                               ToolTip="Jump to Core Plugins"
                               Margin="0,0,4,0"/>
                    <ui:Button Content="Extensions"
                               Icon="{ui:SymbolIcon PuzzlePiece24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Click="JumpToExtensionButton_Click"
                               ToolTip="Jump to Extension Plugins"
                               Margin="0,0,8,0"/>
                    
                    <!-- Refresh Button -->
                    <ui:Button Content="Refresh"
                               Command="{Binding RefreshAllCommand}"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"/>
                </StackPanel>
            </controls:SettingsPageHeader.ActionsContent>
        </controls:SettingsPageHeader>

        <!-- Tab Control: Built-in / External -->
        <TabControl Grid.Row="1"
                    x:Name="PluginsTabControl"
                    SelectionChanged="OnPluginTabChanged"
                    Margin="0,8,0,0"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- Built-in Plugins Tab -->
            <TabItem Header="Built-in">

        <!-- Grouped List with Sticky Header Support -->
        <Grid>
            <ScrollViewer x:Name="PluginsScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0" Style="{StaticResource OverlayScrollViewerStyle}">
                <Grid Width="{Binding ElementName=PluginsScroll, Path=ViewportWidth}">
                    <ItemsControl x:Name="PluginsItemsControl" ItemsSource="{Binding GroupedPlugins}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Group Container -->
                         <Expander IsExpanded="True" Margin="0,0,0,16" Style="{StaticResource PluginsGroupExpanderStyle}" Tag="{Binding GroupName}">
                            <Expander.Header>
                                <TextBlock Text="{Binding GroupName}" Style="{StaticResource GroupHeaderStyle}"/>
                            </Expander.Header>

                            <!-- Plugin List in Group -->
                            <ItemsControl ItemsSource="{Binding Plugins}" Margin="0,8,0,0">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Width" Value="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=ActualWidth}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Plugin Card using ExpandableCard -->
                                         <controls:ExpandableCard 
                                             IconKey="{Binding Icon}"
                                             Title="{Binding Name}"
                                             Subtitle="{Binding Category}"
                                             IsToggleEnabled="{Binding IsEnabled, Mode=TwoWay}"
                                             CanToggle="{Binding CanDisable}"
                                            PrimaryActionCommand="{Binding ConfigureCommand}"
                                            PrimaryActionIcon="Settings24"
                                            PrimaryActionTooltip="Configure"
                                            PrimaryActionVisibility="{Binding HasSettings, Converter={StaticResource BoolToVis}}"
                                            SecondaryActionCommand="{Binding ViewLogsCommand}"
                                            SecondaryActionIcon="DocumentText24"
                                            SecondaryActionTooltip="View Logs"
                                            SecondaryActionVisibility="Visible"
                                            CardContextMenu="{StaticResource PluginContextMenu}">
                                            
                                            <!-- Header Content: Badges + Health Progress -->
                                            <controls:ExpandableCard.HeaderContent>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Core Badge -->
                                                    <Border Visibility="{Binding CanDisable, Converter={StaticResource InverseBoolToVisConverter}}"
                                                            Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                            CornerRadius="4" 
                                                            Padding="4,1" 
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="Core" 
                                                                   FontSize="10" 
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </Border>
                                                    
                                                    <!-- Health Badge -->
                                                    <TextBlock Text="{Binding HealthBadge}" 
                                                               FontSize="14"
                                                               ToolTip="{Binding HealthReport.Status}"
                                                               AutomationProperties.Name="{Binding HealthReport.Status}"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <!-- Health Score with Progress Bar -->
                                                    <TextBlock Text="Health:" 
                                                               FontSize="11" 
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <ProgressBar Value="{Binding HealthReport.HealthScore}" 
                                                                 Maximum="100"
                                                                 Width="60" 
                                                                 Height="4"
                                                                 Foreground="{Binding HealthScoreColor, Converter={StaticResource HexToBrushConverter}}"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                                    
                                                    <TextBlock Text="{Binding HealthScoreText}" 
                                                               FontSize="11" 
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding HealthScoreColor, Converter={StaticResource HexToBrushConverter}}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </controls:ExpandableCard.HeaderContent>
                                            
                                            <!-- Expanded Content: Statistics -->
                                            <controls:ExpandableCard.ExpandedContent>
                                                <StackPanel>
                                                    <!-- Description -->
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="12" 
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,12"/>
                                                    
                                                    <!-- Statistics Row -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                            <ui:SymbolIcon Symbol="ChartMultiple24" 
                                                                           FontSize="14" 
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                           Margin="0,0,6,0"
                                                                           VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding UsageSummary}" 
                                                                       FontSize="12" 
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                            <ui:SymbolIcon Symbol="Folder24" 
                                                                           FontSize="14" 
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                           Margin="0,0,6,0"
                                                                           VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ProfilesSummary}" 
                                                                       FontSize="12" 
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="Clock24" 
                                                                           FontSize="14" 
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                           Margin="0,0,6,0"
                                                                           VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding LastUsedSummary}" 
                                                                       FontSize="12" 
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Performance Metrics Row -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                            <TextBlock Text="⚡" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding AvgExecutionTimeText}" 
                                                                       FontSize="12" 
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                            <TextBlock Text="✓" FontSize="12" Foreground="#28a745" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SuccessRateText}" 
                                                                       FontSize="12" 
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Error Count Badge -->
                                                        <Border Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                                                CornerRadius="4"
                                                                Padding="8,2"
                                                                Visibility="{Binding IsViewLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⚠" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding ViewLogsLabel}" 
                                                                           FontSize="11" 
                                                                           FontWeight="Medium"
                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </controls:ExpandableCard.ExpandedContent>
                                        </controls:ExpandableCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Visibility="{Binding GroupedPlugins.Count, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="Apps24" 
                                   FontSize="48" 
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                    <TextBlock Text="No plugins found" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Try adjusting your search criteria" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ui:Button Content="Clear Search"
                               Command="{Binding ClearSearchCommand}"
                               Icon="{ui:SymbolIcon Dismiss24}"
                               Style="{StaticResource PulsarSecondaryButtonStyle}"
                               Visibility="{Binding SearchText, Converter={StaticResource StringEmptyToVisibilityConverter}}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
            </TabItem>

            <!-- External Plugins Tab -->
            <TabItem Header="External">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- External: Install Button Row -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,8">
                        <ui:Button Content="Install from File"
                                   Command="{Binding ExternalPluginManager.InstallFromFileCommand}"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Style="{StaticResource PulsarPrimaryButtonStyle}"
                                   ToolTip="Install a plugin from a local ZIP file"/>
                    </StackPanel>

                    <!-- External: Scrollable List -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,8,16,0">
                        <StackPanel>
                            <!-- Loading -->
                            <StackPanel Visibility="{Binding ExternalPluginManager.IsLoading, Converter={StaticResource BoolToVis}}"
                                        HorizontalAlignment="Center" Margin="0,48,0,0">
                                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                                <TextBlock Text="Loading external plugins..."
                                           FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,0"/>
                            </StackPanel>

                            <!-- Plugin Cards -->
                            <StackPanel Visibility="{Binding ExternalPluginManager.IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                                <TextBlock Text="{Binding ExternalPluginManager.InstalledPlugins.Count, StringFormat='Installed External Plugins ({0})'}"
                                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <ItemsControl ItemsSource="{Binding ExternalPluginManager.InstalledPlugins}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="8"
                                                    Padding="16" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <controls:SlotOrb Grid.Column="0" IconKey="{Binding Icon}" Size="48"
                                                                       Width="48" Height="48" IsTransparent="True"
                                                                       ShowActiveGlow="False" Margin="0,0,16,0"
                                                                       VerticalAlignment="Top"/>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="12"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}" FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <ui:Button Content="Uninstall"
                                                                   Command="{Binding DataContext.ExternalPluginManager.UninstallPluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                   CommandParameter="{Binding}"
                                                                   Icon="{ui:SymbolIcon Delete24}"
                                                                   Style="{StaticResource PulsarDangerButtonStyle}"
                                                                   MinWidth="100"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="48"
                                        Visibility="{Binding ExternalPluginManager.InstalledPlugins.Count, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Apps24" FontSize="64"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                        <TextBlock Text="No external plugins installed" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Click 'Install from File' to add plugins from ZIP packages"
                                                   FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxWidth="400" Margin="0,0,0,16"/>
                                        <ui:Button Content="Install from File"
                                                   Command="{Binding ExternalPluginManager.InstallFromFileCommand}"
                                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                                   Style="{StaticResource PulsarPrimaryButtonStyle}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Status Bar -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0" Padding="16,8">
                        <TextBlock Text="{Binding ExternalPluginManager.StatusMessage}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
