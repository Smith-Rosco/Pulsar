<Page x:Class="Pulsar.Views.Pages.SettingsPluginsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
      xmlns:ts="clr-namespace:Pulsar.Views.TemplateSelectors"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="SettingsPluginsPage">

    <Page.Resources>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:BoolToStatusStringConverter x:Key="BoolToStatusStringConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PluginsGroupExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ToggleButton Grid.Row="0"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          HorizontalContentAlignment="Left">
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>

                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Row="1"
                                              ContentSource="Content"
                                              Margin="0,8,0,0"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" TargetName="contentPresenter"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PluginDashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        
        <!-- Setting Templates -->
        <DataTemplate x:Key="BooleanSettingTemplate" DataType="{x:Type vm:BooleanSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding BoolValue, Mode=TwoWay}"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="StringSettingTemplate" DataType="{x:Type vm:StringSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:TextBox Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Width="220"
                            HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="SelectionSettingTemplate" DataType="{x:Type vm:SelectionSettingViewModel}">
             <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox ItemsSource="{Binding Options}" 
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          Width="220"
                          HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <ts:PluginSettingTemplateSelector x:Key="SettingSelector"
                                          BooleanTemplate="{StaticResource BooleanSettingTemplate}"
                                          StringTemplate="{StaticResource StringSettingTemplate}"
                                          SelectionTemplate="{StaticResource SelectionSettingTemplate}"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Search Box -->
            <ui:TextBox Grid.Column="0"
                        PlaceholderText="Search plugins..."
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        ClearButtonEnabled="True"
                        HorizontalAlignment="Left"/>
            
            <!-- Refresh Button -->
            <ui:Button Grid.Column="2"
                       Content="Refresh"
                       Command="{Binding RefreshAllCommand}"
                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Appearance="Secondary"/>
        </Grid>

        <!-- Recommendations Section -->
        <ItemsControl Grid.Row="1" 
                      ItemsSource="{Binding Recommendations}"
                      Visibility="{Binding HasRecommendations, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                            BorderBrush="{DynamicResource SystemFillColorAttentionBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding Icon}" 
                                       FontSize="24" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>

                            <!-- Content -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" 
                                           FontWeight="SemiBold" 
                                           FontSize="14"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Message}" 
                                           FontSize="12" 
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Action Button -->
                            <ui:Button Grid.Column="2"
                                       Content="{Binding ActionLabel}"
                                       Command="{Binding DataContext.ExecuteRecommendationActionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}"
                                       Appearance="Secondary"
                                       Margin="12,0,8,0"/>

                            <!-- Dismiss Button -->
                            <ui:Button Grid.Column="3"
                                       Icon="{ui:SymbolIcon Dismiss24}"
                                       Command="{Binding DataContext.DismissRecommendationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}"
                                       Appearance="Secondary"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Grouped List -->
        <ScrollViewer x:Name="PluginsScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Width="{Binding ElementName=PluginsScroll, Path=ViewportWidth}">
                <ItemsControl ItemsSource="{Binding GroupedPlugins}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Group Container -->
                         <Expander IsExpanded="True" Margin="0,0,0,16" Style="{StaticResource PluginsGroupExpanderStyle}">
                            <Expander.Header>
                                <TextBlock Text="{Binding GroupName}" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Expander.Header>

                            <!-- Plugin List in Group -->
                            <ItemsControl ItemsSource="{Binding Plugins}" Margin="0,8,0,0">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Width" Value="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=ActualWidth}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Plugin Card -->
                                        <Border Margin="0,0,0,8" Style="{StaticResource PluginDashboardCardStyle}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Top Row: Icon + Info + Toggle -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" 
                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                                            VerticalAlignment="Top"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Icon}" 
                                                                   FontFamily="{StaticResource PulsarIconFontFamily}"
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   FontSize="24" 
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                    </Border>

                                                    <!-- Info Section -->
                                                    <StackPanel Grid.Column="1" Margin="0">
                                                        <!-- Name & Badges -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Name}" 
                                                                       FontSize="15" 
                                                                       FontWeight="SemiBold"/>
                                                            
                                                            <!-- Core Badge -->
                                                            <Border Visibility="{Binding CanDisable, Converter={StaticResource InverseBoolToVisConverter}}"
                                                                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                    CornerRadius="4" 
                                                                    Padding="6,2" 
                                                                    Margin="8,0,0,0">
                                                                <TextBlock Text="Core" 
                                                                           FontSize="10" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </Border>

                                                            <!-- Health Badge -->
                                                            <TextBlock Text="{Binding HealthBadge}" 
                                                                       FontSize="14" 
                                                                       Margin="8,0,0,0"/>
                                                        </StackPanel>

                                                        <!-- Description -->
                                                        <TextBlock Text="{Binding Description}" 
                                                                   FontSize="12" 
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,8"/>

                                                        <!-- Statistics Row -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                                <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="14" 
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                               Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding UsageSummary}" 
                                                                           FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                                <ui:SymbolIcon Symbol="Folder24" FontSize="14" 
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                               Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding ProfilesSummary}" 
                                                                           FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="Clock24" FontSize="14" 
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                               Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding LastUsedSummary}" 
                                                                           FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Metrics Row -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                                <TextBlock Text="⚡" FontSize="11" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding AvgExecutionTimeText}" 
                                                                           FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                                <TextBlock Text="✓" FontSize="11" Foreground="Green" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding SuccessRateText}" 
                                                                           FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Health:" FontSize="11" 
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                           Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding HealthScoreText}" 
                                                                           FontSize="11" 
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding HealthScoreColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Enable/Disable Toggle -->
                                                    <ui:ToggleSwitch Grid.Column="2" 
                                                                     IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                                                     IsEnabled="{Binding CanDisable}"
                                                                     Content=""
                                                                     VerticalAlignment="Top"
                                                                     Margin="16,0,0,0"/>
                                                </Grid>

                                                <!-- Bottom Row: Action Buttons -->
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="64,12,0,0" HorizontalAlignment="Left">
                                                    <!-- View Logs Button -->
                                                    <ui:Button Content="{Binding ViewLogsLabel}" 
                                                               Command="{Binding ViewLogsCommand}"
                                                               Appearance="Secondary"
                                                               Visibility="{Binding IsViewLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                               Margin="0,0,8,0">
                                                        <ui:Button.Icon>
                                                            <ui:SymbolIcon Symbol="DocumentText24"/>
                                                        </ui:Button.Icon>
                                                    </ui:Button>

                                                    <!-- Configure Button -->
                                                    <ui:Button Content="Configure" 
                                                               Command="{Binding ConfigureCommand}"
                                                               Appearance="Secondary"
                                                               Visibility="{Binding HasSettings, Converter={StaticResource BoolToVis}}">
                                                        <ui:Button.Icon>
                                                            <ui:SymbolIcon Symbol="Settings24"/>
                                                        </ui:Button.Icon>
                                                    </ui:Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Visibility="{Binding GroupedPlugins.Count, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="Apps24" 
                                   FontSize="48" 
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                    <TextBlock Text="No plugins found" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Try adjusting your search criteria" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
