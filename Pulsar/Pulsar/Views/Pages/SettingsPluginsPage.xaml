<Page x:Class="Pulsar.Views.Pages.SettingsPluginsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Pulsar.ViewModels.Settings"
      xmlns:ts="clr-namespace:Pulsar.Views.TemplateSelectors"
      xmlns:converters="clr-namespace:Pulsar.Core.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="SettingsPluginsPage">

    <Page.Resources>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:BoolToStatusStringConverter x:Key="BoolToStatusStringConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
        
        <!-- Setting Templates -->
        <DataTemplate x:Key="BooleanSettingTemplate" DataType="{x:Type vm:BooleanSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding BoolValue, Mode=TwoWay}"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="StringSettingTemplate" DataType="{x:Type vm:StringSettingViewModel}">
            <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:TextBox Text="{Binding StringValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Width="220"
                            HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="SelectionSettingTemplate" DataType="{x:Type vm:SelectionSettingViewModel}">
             <ui:CardControl Margin="0,4" Icon="{Binding Icon}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Description, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox ItemsSource="{Binding Options}" 
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          Width="220"
                          HorizontalAlignment="Right"/>
            </ui:CardControl>
        </DataTemplate>

        <ts:PluginSettingTemplateSelector x:Key="SettingSelector"
                                          BooleanTemplate="{StaticResource BooleanSettingTemplate}"
                                          StringTemplate="{StaticResource StringSettingTemplate}"
                                          SelectionTemplate="{StaticResource SelectionSettingTemplate}"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Search & List -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search Box -->
            <ui:TextBox Grid.Row="0" Margin="0,0,0,12"
                        PlaceholderText="Search plugins..."
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                        ClearButtonEnabled="True"/>

            <!-- Plugin List -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                
                <ListView x:Name="PluginsList"
                          ItemsSource="{Binding FilteredPlugins}" 
                          SelectedItem="{Binding SelectedPlugin, Mode=TwoWay}"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="4">
                    
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon Placeholder (Pulsar Font) -->
                                <Border Width="36" Height="36" CornerRadius="6" Background="{DynamicResource ControlFillColorSecondaryBrush}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" 
                                               FontFamily="{StaticResource PulsarIconFontFamily}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               FontSize="18" FontWeight="Normal" 
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Border>

                                <!-- Name & Info -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <!-- Core Badge -->
                                        <Border Visibility="{Binding CanDisable, Converter={StaticResource InverseBoolToVisConverter}, FallbackValue=Collapsed}"
                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Core" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="30"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <!-- Right Pane: Details -->
        <Grid Grid.Column="1">
            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding SelectedPlugin}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Hero Header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Width="56" Height="56" CornerRadius="12" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Icon}" 
                                       FontFamily="{StaticResource PulsarIconFontFamily}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       FontSize="28" FontWeight="Normal" Foreground="White"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       TextWrapping="Wrap" 
                                       MaxHeight="40"
                                       FontSize="13"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status Control Bar -->
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Status" FontWeight="SemiBold" FontSize="14"/>
                                    <!-- Core Badge -->
                                    <Border Visibility="{Binding CanDisable, Converter={StaticResource InverseBoolToVisConverter}, FallbackValue=Collapsed}"
                                            Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                            CornerRadius="4" Padding="8,3" Margin="10,0,0,0">
                                        <TextBlock Text="Core Plugin (Cannot be disabled)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToStatusStringConverter}}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                             IsEnabled="{Binding CanDisable}"
                                             Content="Enable"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Details Section -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:CardControl Margin="0,0,6,0" Icon="{ui:SymbolIcon Person24}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Author" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding Author}" FontWeight="Medium"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>

                        <ui:CardControl Grid.Column="1" Margin="6,0,0,0" Icon="{ui:SymbolIcon Tag24}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Version" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding Version}" FontWeight="Medium"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </Grid>

                    <Separator Margin="0,12,0,20"/>

                    <!-- Settings Section -->
                    <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding Settings}" ItemTemplateSelector="{StaticResource SettingSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- Empty Settings State -->
                    <ui:CardControl Icon="{ui:SymbolIcon Info24}" 
                                    Header="No Configuration" 
                                    Content="This plugin has no configurable settings.">
                        <ui:CardControl.Style>
                            <Style TargetType="ui:CardControl" BasedOn="{StaticResource {x:Type ui:CardControl}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSettings}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:CardControl.Style>
                    </ui:CardControl>
                    
                    <!-- Bottom Padding -->
                    <Border Height="40"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Empty Selection State -->
            <Grid>
                 <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedPlugin}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6">
                    <ui:SymbolIcon Symbol="PuzzlePiece24" FontSize="48" Margin="0,0,0,16" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="Select a plugin to view details" 
                               HorizontalAlignment="Center" 
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                               FontSize="16"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>