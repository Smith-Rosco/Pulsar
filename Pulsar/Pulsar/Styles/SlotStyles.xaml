<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="SlotChipPadding">8,2</Thickness>
    <CornerRadius x:Key="SlotChipCornerRadius">999</CornerRadius>
    <CornerRadius x:Key="SlotPanelCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="SlotOrbContainerCornerRadius">10</CornerRadius>

    <SolidColorBrush x:Key="SlotTypeBrushDefault" Color="#FF4B5563"/>
    <SolidColorBrush x:Key="SlotTypeBrushSecret" Color="#FFD4A017"/>
    <SolidColorBrush x:Key="SlotTypeBrushApp" Color="#FF0284C7"/>
    <SolidColorBrush x:Key="SlotTypeBrushCommand" Color="#FF15803D"/>
    <SolidColorBrush x:Key="SlotTypeBrushScript" Color="#FFDC2626"/>
    <SolidColorBrush x:Key="SlotTypeBrushVba" Color="#FFB45309"/>

    <SolidColorBrush x:Key="SlotHealthBrushReady" Color="#FF15803D"/>
    <SolidColorBrush x:Key="SlotHealthBrushWarning" Color="#FFD97706"/>
    <SolidColorBrush x:Key="SlotHealthBrushError" Color="#FFDC2626"/>

    <Style x:Key="SlotChipBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource SlotChipCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource SlotChipPadding}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SlotValueChipTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SlotCaptionChipTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SlotSummaryTokenBorderStyle" TargetType="Border" BasedOn="{StaticResource SlotChipBorderStyle}">
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="SlotOrbContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="38"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="CornerRadius" Value="{StaticResource SlotOrbContainerCornerRadius}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SlotPreviewPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource SlotPanelCornerRadius}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,10,0,0"/>
    </Style>

</ResourceDictionary>
