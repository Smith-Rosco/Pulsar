<Application x:Class="Pulsar.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Pulsar.Core.Converters"
             xmlns:dialogs="clr-namespace:Pulsar.ViewModels.Dialogs"
             xmlns:views="clr-namespace:Pulsar.Views.Dialogs.Contents"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 
                     GLOBAL STYLE ISOLATION:
                     We intentionally DO NOT load Wpf.Ui or Pulsar themes globally here.
                     Themes are now injected manually per-window in ThemeService to prevent
                     style contamination between the Radial Menu (Transparent) and Settings (Mica).
                -->
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/ScrollViewerStyles.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Pulsar;component/Styles/TooltipStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type dialogs:ProcessPickerViewModel}">
                <views:ProcessPickerContent/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type dialogs:IconPickerViewModel}">
                <views:IconPickerContent/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type dialogs:InputProfileViewModel}">
                <views:InputProfileContent/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type dialogs:QuickSecretsViewModel}">
                <views:QuickSecretsContent/>
            </DataTemplate>
             <DataTemplate DataType="{x:Type dialogs:EditProfileViewModel}">
                 <views:EditProfileContent/>
             </DataTemplate>
            <DataTemplate DataType="{x:Type dialogs:PluginLogViewerViewModel}">
                <views:PluginLogViewerContentHost/>
            </DataTemplate>

            <converters:ScaleConverter x:Key="ScaleConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <!-- Universal Icon Font Stack - Resolves "Squares" Issue -->
            <!-- Priority: Pulsar Icons > Emoji > Symbols > Text Fallback (CJK/Latin) -->
            <FontFamily x:Key="PulsarIconFontFamily">
                Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei UI, Segoe UI
            </FontFamily>

            <!-- IconButtonStyle preserved as it's used in data templates that we might migrate or reference -->
            <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- Basic Window Style Fallback -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
